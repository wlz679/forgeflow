---
import CopyButton from './CopyButton.astro';
import { t, getLang } from '../i18n';
export interface Props { text: string; index: number; hideIndex?: boolean; }
const { text, index, hideIndex } = Astro.props;
const lang = getLang(Astro);
const stripped = text.split('\n').filter((l: string) => !l.includes('💡 Tip:')).join('\n');
const titleLine = stripped.split('\n')[0];
const restLines = stripped.split('\n').slice(1).join('\n');
---
{
  hideIndex ? (
    <div class="group bg-white border border-gray-100 rounded-2xl overflow-hidden hover:border-[#7C3AED]/30 transition-all duration-300">
      <div class="flex items-start justify-between gap-3 p-5 pb-3 border-b border-gray-50">
        <h3 class="text-base font-bold text-gray-900">{titleLine}</h3>
        <div class="flex items-center gap-0.5 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
          <CopyButton text={stripped} />
          <button type="button" class="export-btn inline-flex items-center gap-1 text-xs text-gray-400 hover:text-[#059669] font-medium px-2 py-1.5 rounded-lg hover:bg-gray-50 transition-all shrink-0" data-export={text}>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <span>{t('btn.export', lang)}</span>
          </button>
        </div>
      </div>
      <div class="p-5 bg-gray-50/50 text-sm text-gray-700 leading-relaxed whitespace-pre-line font-mono">{restLines}</div>
    </div>
  ) : (
    <div class="group flex items-start justify-between gap-4 p-4 bg-white border border-gray-100 rounded-xl hover:border-[#7C3AED]/30 hover:shadow-md hover:shadow-[#7C3AED]/5 transition-all duration-300">
      <span class="text-xs font-bold text-gray-400 shrink-0 pt-0.5 w-5">#{index + 1}</span>
      <span class="text-sm text-gray-700 flex-1 leading-relaxed whitespace-pre-line">{stripped}</span>
      <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        <CopyButton text={stripped} />
      </div>
    </div>
  )
}

<script>
  document.querySelectorAll('.export-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var lines = [];
      lines.push('CalcKit — ' + (document.querySelector('h1')?.textContent || 'Calculator'));
      lines.push('Generated: ' + new Date().toLocaleString());
      var form = document.getElementById('tool-form');
      if (form) {
        lines.push('');
        lines.push('INPUTS');
        lines.push('------');
        form.querySelectorAll('input, select').forEach(function(f) {
          var label = document.querySelector('label[for="' + f.id + '"]');
          lines.push((label ? label.textContent.trim() : f.name) + ': ' + (f.value || '(empty)'));
        });
      }
      lines.push('');
      lines.push('RESULTS');
      lines.push('-------');
      lines.push(this.dataset.export);
      var blob = new Blob([lines.join('\n')], { type: 'text/plain' });
      var a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'calckit-result-' + new Date().toISOString().slice(0, 10) + '.txt';
      a.click();
      URL.revokeObjectURL(a.href);
      var t = this;
      t.style.color = '#059669';
      setTimeout(function() { t.style.color = ''; }, 1500);
    });
  });
</script>
