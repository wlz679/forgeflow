---
import CopyButton from './CopyButton.astro';
export interface Props { text: string; index: number; }
---

<div class="group flex items-start justify-between gap-4 p-4 bg-white border border-gray-100 rounded-xl hover:border-[#FF0000]/30 hover:shadow-md hover:shadow-[#FF0000]/5 transition-all duration-300">
  <span class="text-xs font-bold text-gray-400 shrink-0 pt-0.5 w-5">#{Astro.props.index + 1}</span>
  <span class="text-sm text-gray-700 flex-1 leading-relaxed">{Astro.props.text}</span>
  <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300">
    <CopyButton text={Astro.props.text} />
  </div>
</div>
