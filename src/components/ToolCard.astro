---
import { getLang } from '../i18n';
export interface Props { slug: string; title: string; description: string; }

const lang = getLang(Astro);
---

<a href={`/${lang}/${Astro.props.slug}`} class="group relative flex flex-col p-5 bg-gray-50 border border-gray-100 rounded-xl hover:border-[#FF0000]/30 hover:bg-white hover:shadow-lg hover:shadow-[#FF0000]/5 transition-all duration-300 hover:-translate-y-1">
  <div class="flex items-start justify-between mb-3">
    <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center border border-gray-100 shadow-sm">
      <svg class="w-5 h-5 text-[#FF0000]" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
      </svg>
    </div>
    <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      <svg class="w-5 h-5 text-[#FF0000]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
  <h3 class="text-base font-semibold text-gray-900 group-hover:text-[#FF0000] transition-colors duration-300 mb-2">{Astro.props.title}</h3>
  <p class="text-sm text-gray-500 line-clamp-2 group-hover:text-gray-600 transition-colors duration-300 mt-auto">{Astro.props.description}</p>
  <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-[#FF0000] to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-b-xl"></div>
</a>