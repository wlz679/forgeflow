---
import ToolCard from './ToolCard.astro';
export interface Props { id: string; name: string; description: string; tools: { slug: string; title: string; description: string }[]; }
---

<section id={Astro.props.id} class="mb-10 p-6 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300">
  <div class="flex items-center gap-3 mb-5">
    <div class="w-1 h-8 bg-gradient-to-b from-[#FF0000] to-orange-400 rounded-full"></div>
    <div>
      <h2 class="text-lg font-bold text-gray-900">{Astro.props.name}</h2>
      <p class="text-xs text-gray-500">{Astro.props.description}</p>
    </div>
    <span class="ml-auto text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded">
      {Astro.props.tools.length} tools
    </span>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    {Astro.props.tools.map(tool => <ToolCard {...tool} />)}
  </div>
</section>
