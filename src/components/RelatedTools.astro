---
import { t, getLang } from '../i18n';

export interface Props { tools: { slug: string; title: string }[]; }

const lang = getLang(Astro);
---

<div class="mt-8">
  <h2 class="text-lg font-bold text-gray-900 mb-4">{t('related_tools.title', lang)}</h2>
  <div class="flex flex-wrap gap-2">
    {Astro.props.tools.map(tool => (
      <a href={`/${lang}/${tool.slug}`} class="inline-flex items-center gap-2 px-4 py-2 text-sm bg-gray-50 border border-gray-100 rounded-full hover:border-[#7C3AED]/30 hover:bg-white hover:text-[#7C3AED] transition-all duration-300">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
        </svg>
        {tool.title}
      </a>
    ))}
  </div>
</div>