    '风口之上 🟢 — 顺势而为，抓住窗口期',
  ],
};

const engine: ToolEngine = {
  slug: 'solopreneur-startup-idea-validator',
  title: 'Startup Idea Validator',
  description: 'Rate your startup idea across market size, competition, monetization, and execution difficulty.',
  category: 'A',
  inputs: [
    { name: 'topic', label: 'Your Startup Idea', placeholder: 'e.g. AI-powered meal planner for busy parents', type: 'text' },
  ],
  clientConfig: { type: 'templates', templates, wordPools },
  generate(inputs) {
    // Server-side: use the helper with English fallback (same structure, different content)
    const enWordPools = {
      marketSize: wordPools.marketSize,
      marketDetail: wordPools.marketDetail,
      competition: wordPools.competition,
      competitionDetail: wordPools.competitionDetail,
      monetization: wordPools.monetization,
      monetizationDetail: wordPools.monetizationDetail,
      effort: wordPools.effort,
      verdict: wordPools.verdict,
    };
    const results: string[] = [];
    const seen = new Set<string>();
    let attempts = 0;
    while (results.length < 10 && attempts < 150) {
      attempts++;
      const tpl = randomPick(templates);
      const vars: Record<string, string> = { topic: inputs.topic || 'your idea' };
      for (const [key, pool] of Object.entries(enWordPools)) {
        vars[key] = randomPick(pool);
      }
      // Simple template fill
      const filled = tpl.replace(/\{(\w+)\}/g, (_, k) => vars[k] || `{${k}}`).trim();
      if (!seen.has(filled)) { seen.add(filled); results.push(filled); }
    }
    return results;
  },
  staticExamples: [
    '📊 AI meal planner\n\n📈 市场规模 5000万-2亿美元（中型市场）\n年增速约15-22%，中端市场公司推动增长。独立开发者可以切入其中未被巨头充分服务的细分领域。\n\n⚔️ 竞争分析 中（差异化可行）\n目前没有直接竞品完全覆盖你的目标场景。这是一个时间窗口——快速发布、收集反馈、迭代优化。\n\n💰 变现模式 SaaS 订阅（$29-$199/月）\nSaaS订阅模式最适合：初始定价从$29/月（入门版）到$99/月（专业版）。\n\n🔨 所需投入 1-3个月单人全职\n\n🏆 值得做 🟢 — 需求明确，利润可观',
    '📊 newsletter for indie hackers\n\n📈 市场 20万-100万美元（微小但可盈利）\n碎片化市场，没有绝对领导者。通过专注单一垂直场景可以快速建立口碑。\n\n⚔️ 竞争格局 低-中（有主导空间）\n间接竞品为主——用户在拼凑多个通用工具来完成工作流。\n\n💰 收入模型 分级会员（$10-$100/月）\n对于专业工具，不要低估一次性定价的力量。$199终身版对独立开发者非常有吸引力。\n\n⏱ 时间投入 无代码工具2-3周\n\n✅ 建议：利基金矿 🟢 — 小市场但用户忠诚度高',
    '📊 DTC coffee brand\n\n📈 TAM 估算 2亿-10亿美元（整合中市场）\n成熟市场增速放缓至5-8%，但用户预算充足。关键在用户体验和细分场景上做深。\n\n⚔️ 竞争密度 高（同质化严重，靠体验竞争）\n竞争对手资金充裕但研发速度慢。你可以用更快迭代和更贴近用户的定价策略来竞争。\n\n💰 变现模式 一次性付费（$49-$499）\n平台抽佣适合平台型产品。5-15%是行业标准范围。\n\n🛠 构建周期 30天出MVP，边跑边迭代\n\n🎯 结论：有风险 🟡 — 赛道拥挤但存在突破口',
    '📊 SaaS onboarding tool\n\n📈 市场规模 1亿-5亿美元（成熟市场）\n由2-3个玩家主导，但他们在中小客户上服务体验较差——这是你的机会窗口。\n\n⚔️ 竞争分析 中-高（需要强大切入点）\n大公司的产品功能臃肿且定价昂贵。做一个简化的、价格透明的小团队替代品。\n\n💰 变现模式 按用量计费\n按用量计费对API/基础设施类产品最合适。设定一个慷慨的免费额度。\n\n🔨 所需投入 AI辅助开发1-2个月\n\n🏆 值得一试 🟢 — 先做落地页验证需求',
    '📊 online course platform\n\n📈 市场 5000万-2亿美元（中型市场）\n快速增长期（25%+ CAGR），窗口期有限，先发优势明显。\n\n⚔️ 竞品密度 中（差异化可行）\n有2-3个玩家，但他们在用户体验或定价上存在明显弱点。\n\n💰 最佳变现路径 免费增值 → 付费升级\n免费增值模式建议：核心功能免费吸引用户，付费墙放在高级分析上。\n\n⏱ 时间投入 3-6个月全职投入\n\n✅ 建议：强烈推荐 🟢 — 已验证需求，稳定回报',
  ],
  faq: [
    { q: 'How reliable is this idea validator?', a: 'It uses structured evaluation across four dimensions that investors and accelerators actually use. Treat it as a starting point for deeper research, not a final answer.' },
    { q: 'What makes an idea "validated"?', a: 'A validated idea has: paying customers, a clear problem, reasonable market size, and a distribution channel you control. This tool helps you think through those criteria.' },
    { q: 'Should I trust the verdict if it says SKIP?', a: 'Use it as a signal, not a decree. Many great companies were initially rated poorly. But if multiple evaluations point to "skip", investigate why before quitting your job.' },
    { q: 'How does the effort rating work?', a: 'It estimates solo-founder build time using modern tools (no-code, AI-assisted dev). A "weekend project" means an MVP is genuinely testable in 48 hours.' },
    { q: 'Which metric matters most?', a: 'For solopreneurs, monetization model matters most — you need cash flow fast. For VC-scale, market size dominates. For lifestyle businesses, competition level is key.' },
  ],
  howToUse: [
    'Type your startup or product idea in the input field.',
    'Click "Generate" to get 10 scored evaluations.',
    'Click expand ▼ on any result to see the full analysis.',
    'Each report covers market size, competition, monetization, effort, and a verdict.',
    'Look for consensus across multiple evaluations — do they trend positive or negative?',
  ],
};

registerEngine(engine);
