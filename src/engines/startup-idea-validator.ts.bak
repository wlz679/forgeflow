import type { ToolEngine } from '../core/engines/types';
import { randomPick } from '../core/engines/helpers';
import { registerEngine } from '../core/engines/registry';

// Multi-line templates: each result is a structured report separated by \n\n
// First line = preview (always shown), rest = detail (expandable)
const templates = [
  '📊 {topic}\n\n📈 市场规模 {marketSize}\n{marketDetail}\n\n⚔️ 竞争分析 {competition}\n{competitionDetail}\n\n💰 变现模式 {monetization}\n{monetizationDetail}\n\n🔨 所需投入 {effort}\n\n🏆 {verdict}',
  '📊 {topic}\n\n📈 市场 {marketSize}\n{marketDetail}\n\n⚔️ 竞品密度 {competition}\n{competitionDetail}\n\n💡 最佳变现路径 {monetization}\n{monetizationDetail}\n\n🛠 构建周期 {effort}\n\n🎯 结论：{verdict}',
  '📊 {topic}\n\n📈 TAM 估算 {marketSize}\n{marketDetail}\n\n⚔️ 竞争格局 {competition}\n{competitionDetail}\n\n💰 收入模型 {monetization}\n{monetizationDetail}\n\n⏱ 时间投入 {effort}\n\n✅ 建议：{verdict}',
];

