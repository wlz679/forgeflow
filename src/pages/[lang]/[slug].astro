      // Business calc config (24 non-AI calcs grouped into 4 visual families)
      var BIZ_CONFIG_MAP = { 'solopreneur-mrr-calculator':'BIZ_SAAS','solopreneur-burn-rate-calculator':'BIZ_SAAS','solopreneur-churn-rate-calculator':'BIZ_SAAS','solopreneur-market-size-estimator':'BIZ_SAAS','solopreneur-revenue-projector':'BIZ_SAAS','solopreneur-ltv-calculator':'BIZ_VALUATION','solopreneur-cac-calculator':'BIZ_VALUATION','solopreneur-unit-economics-calculator':'BIZ_VALUATION','solopreneur-saas-valuation-calculator':'BIZ_VALUATION','solopreneur-equity-dilution-calculator':'BIZ_VALUATION','solopreneur-break-even-calculator':'BIZ_VALUATION','solopreneur-freelance-rate-calculator':'BIZ_FREELANCE','solopreneur-course-pricing-calculator':'BIZ_FREELANCE','solopreneur-time-value-calculator':'BIZ_FREELANCE','solopreneur-sponsorship-rate-calculator':'BIZ_FREELANCE','solopreneur-project-profitability-calculator':'BIZ_FREELANCE','solopreneur-affiliate-income-calculator':'BIZ_FREELANCE','solopreneur-email-list-revenue-calculator':'BIZ_FREELANCE','solopreneur-hourly-vs-fixed-calculator':'BIZ_FREELANCE','solopreneur-meeting-cost-calculator':'BIZ_COST','solopreneur-employee-cost-calculator':'BIZ_COST','solopreneur-productivity-score':'BIZ_COST','solopreneur-saas-pricing-planner':'BIZ_COST','solopreneur-freelance-tax-calculator':'BIZ_COST' };
      var bizConfigKey = BIZ_CONFIG_MAP[toolSlug];
      function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
      function fill(t, v) { return t.replace(/\{(\w+)\}/g, function(_, k) { return v[k] ?? '{' + k + '}'; }); }
      function generateFromConfig(config, inputs) {
        if (config.type === 'custom' && config.customFn) {
          var fn = new Function('inputs', 'pick', 'fill', config.customFn);
          return fn(inputs, pick, fill);
        }
        var count = 10;
        var v = { topic: inputs.topic || inputs.niche || inputs.keyword || inputs.interest || inputs.title || 'your topic', niche: inputs.niche || inputs.topic || 'your niche', keyword: inputs.keyword || inputs.topic || 'your keyword' };
        var results = [];
        var seen = {};
        var attempts = 0;
        while (results.length < count && attempts < count * 15) {
          attempts++;
          for (var key in config.wordPools) v[key] = pick(config.wordPools[key]);
          var result = '';
          if (config.type === 'templates') result = fill(pick(config.templates), v).trim();
          else if (config.type === 'combinations') result = pick(config.patterns)(v).trim();
          if (result && !seen[result]) { seen[result] = true; results.push(result); }
        }
        return results;
      }

      // ===== Unified beautification engine — handles ALL calculators =====
      // Config-driven: beautifySections(text, CONFIG) replaces 8 individual functions
      // renderCard() is a shared helper for detail-card rendering

      function beautifySections(text, config) {
        var rawSections = text.split(/\n\n(?=\S)/);
        var sections = [];
        for (var rsi = 0; rsi < rawSections.length; rsi++) {
          var rs = rawSections[rsi].trim();
          if (!rs) continue;
          if (sections.length > 0 && rs.length < 60 && sections[sections.length - 1].indexOf('\n') < 0) {
            sections[sections.length - 1] += '\n' + rs;
          } else {
            sections.push(rs);
          }
        }
        if (sections.length <= 1) sections = [text];

        var html = '';
        var familyIcons = Object.keys(config.families).join('');

        for (var si = 0; si < sections.length; si++) {
          var s = sections[si].trim();
          if (!s) continue;

          // --- Bar Chart Section ---
          if (s.indexOf('Cost Comparison') >= 0 || (s.indexOf('█') >= 0 && s.split('\n').length >= 3)) {
            var lines = s.split('\n');
            var maxCost = 0;
            var bars = [];
            var isBarSection = false;

            for (var li = 0; li < lines.length; li++) {
              var l = lines[li];
              // Match: [icon or prefix] label  spaces  █░bars  spaces  $cost[/unit]
              var m = l.match(/^(.+?)\s{2,}([█░]+)\s+[\$](\S+)/u);
              if (m) {
                isBarSection = true;
                var label = m[1];
                var icon = '';
                // Extract icon: single emoji/char, variation selector, or [X] prefix
                var im = label.match(/^(\[[A-Z]\]|\S️?)\s/u);
                if (im) { icon = im[1]; label = label.slice(im[0].length).trim(); }
                var cost = parseFloat(m[3].replace(/,/g,''));
                if (cost > maxCost) maxCost = cost;
                bars.push({ icon: icon, name: label, blocks: m[2], cost: '$' + m[3], badge: '', raw: l });
              }
            }

            if (isBarSection && bars.length > 0) {
              html += '<div class="mb-4">';
              html += '<h4 class="text-sm font-bold text-gray-800 mb-3">' + esc(lines[0]) + '</h4>';
              for (var bi = 0; bi < bars.length; bi++) {
                var b = bars[bi];
                var fam = config.families[b.icon] || config.defaultFamily;
                var pct = maxCost > 0 ? Math.round((parseFloat(b.cost.replace('$','').replace(/,/g,'')) / maxCost) * 100) : 0;
                html += '<div class="flex items-center gap-2 mb-1.5 text-xs">';
                html += '<span class="w-32 shrink-0 truncate text-gray-700" style="color:' + (fam.text || fam.bar) + ';font-weight:600">' + esc(b.icon + ' ' + b.name) + '</span>';
                html += '<span class="flex-1 h-4 rounded-sm relative" style="background:#f3f4f6">';
                html += '<span class="absolute inset-y-0 left-0 rounded-sm transition-all" style="width:' + Math.max(1, pct) + '%;background:' + fam.bar + '"></span>';
                html += '</span>';
                html += '<span class="w-20 text-right font-semibold text-gray-800">' + b.cost + '</span>';
                if (b.badge) html += '<span class="text-xs text-amber-600 font-medium">' + esc(b.badge) + '</span>';
                html += '</div>';
              }
              html += '</div>';
              continue;
            }
          }

          // --- Detail Cards Section ---
          if (s.indexOf('Context:') >= 0 || s.indexOf('Rate:') >= 0 || s.indexOf('Per Request:') >= 0 || s.indexOf('Input:') >= 0 || s.indexOf('Selected Model Details') >= 0) {
            var cardLines = s.split('\n');
            var iconRx2 = config.iconRegex;

            html += '<div class="space-y-3">';
            if (cardLines[0] && !cardLines[0].match(iconRx2) && cardLines[0].trim().length < 120) {
              html += '<h4 class="text-sm font-bold text-gray-800 mb-1">' + esc(cardLines[0].trim()) + '</h4>';
            }

            var currentCard = null;
            var cardContent = [];

            for (var cli = 0; cli < cardLines.length; cli++) {
              var cl = cardLines[cli];
              var cardMatch = cl.match(iconRx2);
              var isCardHeader = cardMatch && (cl.indexOf('(') >= 0 || cl.indexOf('|') >= 0) && !cl.startsWith('  ');
              if (isCardHeader) {
                if (currentCard) {
                  html += renderCard(currentCard, cardContent, config);
                }
                currentCard = { icon: cardMatch[1] || cardMatch[0], raw: cl };
                cardContent = [];
              } else if (cl.trim()) {
                cardContent.push(cl);
              }
            }
            if (currentCard) {
              html += renderCard(currentCard, cardContent, config);
            }
            html += '</div>';
            continue;
          }

          // --- Caching / Reasoning Breakdown Section ---
          if (s.indexOf('Caching Breakdown') >= 0 || s.indexOf('Cache Breakdown') >= 0 || s.indexOf('🧠 Reasoning') >= 0) {
            var blines = s.split('\n').filter(function(l){ return l.trim(); });
            html += '<div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 mb-3">';
            html += '<h4 class="text-sm font-bold text-gray-800 mb-2">' + esc(blines[0]) + '</h4>';
            for (var bli = 1; bli < blines.length; bli++) {
              var bl = blines[bli].trim();
              if (!bl) continue;
              if (bl.indexOf('Break-even') >= 0 || bl.indexOf('Monthly') >= 0) {
                html += '<div class="text-xs font-semibold text-emerald-700 mt-1">' + esc(bl) + '</div>';
              } else {
                html += '<div class="text-xs text-gray-600">' + esc(bl) + '</div>';
              }
            }
            html += '</div>';
            continue;
          }

          // --- Growth Projection Section ---
          if (s.indexOf('Growth Projection') >= 0) {
            var glines = s.split('\n');
            html += '<div class="mb-4">';
            html += '<h4 class="text-sm font-bold text-gray-800 mb-2">' + esc(glines[0]) + '</h4>';
            html += '<div class="overflow-x-auto"><table class="w-full text-xs border-collapse"><thead><tr class="bg-gray-100">';
            var hdrLine = -1;
            for (var hli = 1; hli < Math.min(glines.length, 5); hli++) {
              if (glines[hli] && glines[hli].indexOf('│') >= 0) { hdrLine = hli; break; }
            }
            var hdrParts = hdrLine >= 0 ? glines[hdrLine].split('│') : [];
            for (var hi = 0; hi < hdrParts.length; hi++) {
              html += '<th class="px-2 py-1.5 text-left font-semibold text-gray-600">' + esc(hdrParts[hi].trim()) + '</th>';
            }
            html += '</tr></thead><tbody>';
            var dataStart = hdrLine + 2;
            for (var ri = dataStart; ri < glines.length; ri++) {
              if (!glines[ri] || glines[ri].indexOf('💡') >= 0) break;
              var cells = glines[ri].split('│');
              if (cells.length < 2) continue;
              var isTotal = glines[ri].trim().startsWith('Total') || glines[ri].trim().startsWith('Cumulative');
              html += '<tr class="border-t border-gray-100' + (isTotal ? ' bg-gray-50 font-semibold' : '') + '">';
              for (var ci = 0; ci < cells.length; ci++) {
                html += '<td class="px-2 py-1.5 text-gray-700">' + esc(cells[ci].trim()) + '</td>';
              }
              html += '</tr>';
            }
            for (var ri2 = dataStart; ri2 < glines.length; ri2++) {
              if (glines[ri2] && glines[ri2].indexOf('💡') >= 0) {
                html += '<tr><td colspan="' + hdrParts.length + '" class="px-2 py-1.5 text-xs text-purple-700 font-medium">' + esc(glines[ri2].trim()) + '</td></tr>';
              }
            }
            html += '</tbody></table></div></div>';
            continue;
          }

          // --- Savings Insights / Cross-provider Section ---
          if (s.indexOf('Savings Insights') >= 0 || s.indexOf('Savings vs') >= 0) {
            var slines = s.split('\n').filter(function(l){ return l.trim() && l.indexOf('───') < 0 && l.indexOf('━━') < 0; });
            html += '<div class="rounded-xl border border-amber-200 bg-amber-50 p-4 mb-3">';
            html += '<h4 class="text-sm font-bold text-gray-800 mb-2">💰 Savings Insights</h4>';
            for (var sli = 0; sli < slines.length; sli++) {
              var sl = slines[sli].trim();
              if (!sl || sl.indexOf('Savings Insights') >= 0) continue;
              if (sl.indexOf('🏆') >= 0 || sl.indexOf('saves') >= 0 || sl.indexOf('cheaper') >= 0) {
                html += '<div class="text-xs font-semibold text-green-700">' + esc(sl) + '</div>';
              } else if (sl.indexOf('⭐') >= 0 || sl.indexOf('costs') >= 0 || sl.indexOf('premium') >= 0) {
                html += '<div class="text-xs font-medium text-amber-700">' + esc(sl) + '</div>';
              } else if (sl.indexOf('💡') >= 0 || sl.indexOf('💸') >= 0) {
                html += '<div class="text-xs text-purple-700 mt-1 font-medium">' + esc(sl) + '</div>';
              } else if (sl.indexOf('🌍') >= 0 || sl.indexOf('🌐') >= 0) {
                html += '<div class="text-xs text-indigo-700 mt-0.5">' + esc(sl) + '</div>';
              } else if (sl.indexOf('💾') >= 0 || sl.indexOf('🗜️') >= 0) {
                html += '<div class="text-xs text-teal-700 mt-0.5">' + esc(sl) + '</div>';
              } else if (sl.trim()) {
                html += '<div class="text-xs text-gray-600 mt-0.5">' + esc(sl) + '</div>';
              }
            }
            html += '</div>';
            continue;
          }

          // --- Usage Scenarios Section ---
          if (s.indexOf('Usage Scenarios') >= 0) {
            var ulines = s.split('\n').filter(function(l){ return l.trim() && l.indexOf('───') < 0 && l.indexOf('━━') < 0; });
            html += '<div class="mb-3">';
            html += '<h4 class="text-sm font-bold text-gray-800 mb-2">📊 Usage Scenarios (monthly costs)</h4>';
            html += '<div class="space-y-1">';
            for (var uli = 0; uli < ulines.length; uli++) {
              var ul = ulines[uli].trim();
              if (!ul || ul.indexOf('Usage Scenarios') >= 0) continue;
              var um = ul.match(/^(\S)\s+(.+?):\s+(.+)/);
              if (um) {
                var uIcon = um[1];
                var uName = um[2];
                var uData = um[3];
                var uFam = config.families[uIcon] || config.defaultFamily;
                html += '<div class="flex items-center gap-2 text-xs py-1.5 px-2 rounded" style="background:' + uFam.bg + '">';
                html += '<span class="font-semibold text-gray-800 w-36 shrink-0 truncate" style="color:' + (uFam.text || uFam.bar) + '">' + esc(uIcon + ' ' + uName) + '</span>';
                html += '<span class="text-gray-600">' + esc(uData).replace(/·/g, '<span class="text-gray-300 mx-1">·</span>') + '</span>';
                html += '</div>';
              }
            }
            html += '</div></div>';
            continue;
          }

          // --- Header section (pricing mode, input summary, cache note) ---
          if (s.indexOf('Input:') >= 0 || s.indexOf('📥') >= 0 || s.indexOf('📤') >= 0) {
            var hlines = s.split('\n').filter(function(l){ return l.trim(); });
            html += '<div class="rounded-lg bg-gradient-to-r from-gray-50 to-blue-50/30 border border-gray-200 p-3 mb-4">';
            for (var hi2 = 0; hi2 < hlines.length; hi2++) {
              var hl = hlines[hi2].trim();
              if (hl.indexOf('📥') >= 0 || hl.indexOf('📤') >= 0) {
                html += '<div class="text-xs font-medium text-gray-700">' + esc(hl) + '</div>';
              } else if (hl.indexOf('💾') >= 0 || hl.indexOf('cache') >= 0) {
                html += '<div class="text-xs text-emerald-700 font-medium mt-0.5">' + esc(hl) + '</div>';
              } else {
                html += '<div class="text-sm font-bold text-gray-800">' + esc(hl) + '</div>';
              }
            }
            html += '</div>';
            continue;
          }

          // --- Fallback: render as text block ---
          html += '<div class="text-xs text-gray-600 whitespace-pre-line bg-gray-50 rounded-lg p-3 mb-3">' + esc(s) + '</div>';
        }
        return html;
      }

      // Helper: render a detail card for one model/provider
      function renderCard(card, content, config) {
        var fam = config.families[card.icon] || config.defaultFamily;
        var nameMatch = card.raw.match(/^\S\s+(.+?)\s*[\(|]/);
        var name = nameMatch ? nameMatch[1].trim() : card.raw;
        var famMatch = card.raw.match(/\((.+?)\)/);
        var famLabel = famMatch ? famMatch[1] : '';
        var ctxMatch = card.raw.match(/\|\s*Context:\s*(.+)/);
        var ctxLabel = ctxMatch ? ctxMatch[1] : '';

        var h = '';
        h += '<div class="rounded-xl border p-4" style="border-color:' + fam.border + ';background:' + fam.bg + '">';
        h += '<div class="flex items-center gap-2 mb-2">';
        h += '<span style="color:' + (fam.text || fam.bar) + ';font-weight:bold">' + esc(card.icon) + '</span>';
        h += '<span class="font-semibold text-sm text-gray-900">' + esc(name) + '</span>';
        if (famLabel || ctxLabel) {
          h += '<span class="text-xs text-gray-400 ml-auto">' + esc(famLabel || ctxLabel) + '</span>';
        }
        h += '</div>';

        for (var i = 0; i < content.length; i++) {
          var l = content[i].trim();
          if (!l) continue;
          if (l.indexOf('Context:') >= 0 || l.indexOf('Rate:') >= 0) {
            h += '<div class="text-xs text-gray-500 ml-5">' + esc(l) + '</div>';
          } else if (l.indexOf('Per Request:') >= 0 || l.indexOf('Per request:') >= 0 || l.indexOf('Monthly Cost') >= 0 || l.indexOf('Monthly:') >= 0 || l.indexOf('Annual') >= 0 || l.indexOf('Daily') >= 0) {
            h += '<div class="text-xs font-semibold text-gray-800 ml-5 mt-0.5">' + esc(l) + '</div>';
          } else if (l.indexOf('💾') >= 0 || l.indexOf('cache') >= 0 || l.indexOf('With caching') >= 0) {
            h += '<div class="text-xs text-emerald-700 ml-5 mt-0.5 font-medium">' + esc(l) + '</div>';
          } else if (l.indexOf('Batch') >= 0 || l.indexOf('Real-time') >= 0 || l.indexOf('reasoning') >= 0 || l.indexOf('🧠') >= 0) {
            h += '<div class="text-xs text-blue-700 ml-5 mt-0.5">' + esc(l) + '</div>';
          } else if (l.trim()) {
            h += '<div class="text-xs text-gray-600 ml-5">' + esc(l) + '</div>';
          }
        }
        h += '</div>';
        return h;
      }

