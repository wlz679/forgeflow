        },
        iconRegex: /[🔵🟢🟠⚪]/u,
        defaultFamily: { bg: '#f9fafb', bar: '#9ca3af', border: '#e5e7eb' },
      };

      // Claude family config
      var CLAUDE_CONFIG = {
        families: {
          '✦': { bg: '#f5f3ff', bar: '#7c3aed', border: '#ddd6fe', text: '#7c3aed' },
          '▲': { bg: '#eff6ff', bar: '#2563eb', border: '#bfdbfe', text: '#2563eb' },
          '◆': { bg: '#f9fafb', bar: '#6b7280', border: '#e5e7eb', text: '#6b7280' },
        },
        iconRegex: /[✦▲◆]/u,
        defaultFamily: { bg: '#f9fafb', bar: '#6b7280', border: '#e5e7eb' },
