{isInteractive && (
  <>
    <script define:vars={{ clientConfig, exportLabel: t('btn.export', lang), toolSlug: slug }}>
      var isOpenAI = toolSlug === 'solopreneur-openai-token-calculator';
      var isClaude = toolSlug === 'solopreneur-claude-api-cost-calculator';
      var isDeepSeek = toolSlug === 'solopreneur-deepseek-api-cost-calculator';
      var isGemini = toolSlug === 'solopreneur-gemini-api-cost-calculator';
      var isAiApiCostComparison = toolSlug === 'solopreneur-ai-api-cost-comparison';
      var isImage = toolSlug === 'solopreneur-ai-image-cost-calculator';
      var isTraining = toolSlug === 'solopreneur-ai-training-cost-estimator';
      var isGpu = toolSlug === 'solopreneur-gpu-cloud-cost-calculator';
      function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
      function fill(t, v) { return t.replace(/\{(\w+)\}/g, function(_, k) { return v[k] ?? '{' + k + '}'; }); }
      function generateFromConfig(config, inputs) {
        if (config.type === 'custom' && config.customFn) {
          var fn = new Function('inputs', 'pick', 'fill', config.customFn);
          return fn(inputs, pick, fill);
        }
        var count = 10;
        var v = { topic: inputs.topic || inputs.niche || inputs.keyword || inputs.interest || inputs.title || 'your topic', niche: inputs.niche || inputs.topic || 'your niche', keyword: inputs.keyword || inputs.topic || 'your keyword' };
        var results = [];
        var seen = {};
        var attempts = 0;
        while (results.length < count && attempts < count * 15) {
          attempts++;
          for (var key in config.wordPools) v[key] = pick(config.wordPools[key]);
          var result = '';
          if (config.type === 'templates') result = fill(pick(config.templates), v).trim();
          else if (config.type === 'combinations') result = pick(config.patterns)(v).trim();
          if (result && !seen[result]) { seen[result] = true; results.push(result); }
        }
        return results;
      }

      // Beautify OpenAI calculator text output into styled HTML sections
      function beautifyOpenAI(text) {
        var sections = text.split(/\n(?=[\u{1F4CA}\u{1F4CB}\u{1F4C8}\u{1F4B0}\u{1F4C5}\u{1F534}⚡])/u);
        var html = '';
        var familyColors = {
          '\u{1F535}': { bg: '#eff6ff', bar: '#3b82f6', border: '#bfdbfe' },   // 🔵 GPT-5 blue
          '\u{1F7E2}': { bg: '#f0fdf4', bar: '#22c55e', border: '#bbf7d0' },   // 🟢 GPT-4.1 green
          '\u{1F7E0}': { bg: '#fff7ed', bar: '#f97316', border: '#fed7aa' },   // 🟠 o-series orange
          '⚪':    { bg: '#f9fafb', bar: '#9ca3af', border: '#e5e7eb' },   // ⚪ legacy gray
        };

        for (var si = 0; si < sections.length; si++) {
          var s = sections[si].trim();
          if (!s) continue;

          // --- Bar Chart Section ---
          if (s.indexOf('Cost Comparison') >= 0) {
            var lines = s.split('\n');
            // Find max cost for bar scaling
            var maxCost = 0;
            var bars = [];
            for (var li = 0; li < lines.length; li++) {
              var l = lines[li];
              var famIcon = l.charAt(0) + (l.charAt(1) === '️' ? l.charAt(1) : '');
              // Match: icon padded_name █blocks $cost [badge]
              var m = l.match(/^([\u{1F535}\u{1F7E2}\u{1F7E0}⚪])\s+(.+?)\s+(█+)\s+(\$\S+)(.*)/u);
              if (m) {
                var cost = parseFloat(m[4].replace('$','').replace(/,/g,''));
                if (cost > maxCost) maxCost = cost;
                bars.push({ icon: m[1], name: m[2].trim(), blocks: m[3].length, cost: m[4], badge: (m[5]||'').trim(), raw: l });
              }
            }
            // Also parse header line from raw text
            var titleMatch = s.match(/([\u{1F4CA}])\s*(Cost Comparison.*)/u);
            html += '<div class="mb-4">';
            html += '<h4 class="text-sm font-bold text-gray-800 mb-3">' + esc(s.split('\n')[0]) + '</h4>';
            for (var bi = 0; bi < bars.length; bi++) {
              var b = bars[bi];
              var fam = familyColors[b.icon] || familyColors['⚪'];
              var pct = maxCost > 0 ? Math.round((parseFloat(b.cost.replace('$','').replace(/,/g,'')) / maxCost) * 100) : 0;
              html += '<div class="flex items-center gap-2 mb-1.5 text-xs">';
              html += '<span class="w-28 truncate text-gray-700">' + b.icon + ' ' + esc(b.name) + '</span>';
              html += '<span class="flex-1 h-4 rounded-sm relative" style="background:#f3f4f6">';
              html += '<span class="absolute inset-y-0 left-0 rounded-sm transition-all" style="width:' + Math.max(1, pct) + '%;background:' + fam.bar + '"></span>';
              html += '</span>';
              html += '<span class="w-16 text-right font-semibold text-gray-800">' + b.cost + '</span>';
              if (b.badge) html += '<span class="text-xs text-amber-600 font-medium">' + esc(b.badge) + '</span>';
              html += '</div>';
            }
            html += '</div>';
            continue;
          }

          // --- Detail Cards Section ---
          if (s.indexOf('Selected Model Details') >= 0) {
            var cardLines = s.split('\n');
            html += '<h4 class="text-sm font-bold text-gray-800 mb-3">' + esc(cardLines[0]) + '</h4>';
            // Parse individual cards: lines starting with family icon + model name
            var cardStart = 2; // skip header + separator
            while (cardStart < cardLines.length) {
              var cl = cardLines[cardStart];
              if (!cl || cl.indexOf('──') >= 0 || cl.indexOf('━━') >= 0) { cardStart++; continue; }
              // Check if this line starts a new card: icon + model name + | Context:
              var cardMatch = cl.match(/([\u{1F535}\u{1F7E2}\u{1F7E0}⚪])\s+(.+?)\s+\|\s+Context:\s+(.+)/u);
              if (cardMatch) {
                var cIcon = cardMatch[1];
                var cName = cardMatch[2];
                var cCtx = cardMatch[3];
                var fam = familyColors[cIcon] || familyColors['⚪'];
                var cardEnd = cardStart + 1;
                // Find end of this card (next icon+name line or end of section)
                while (cardEnd < cardLines.length) {
                  var nl = cardLines[cardEnd];
                  if (nl.match(/^[\u{1F535}\u{1F7E2}\u{1F7E0}⚪]\s+\S+\s+\|/u)) break;
                  if (nl.indexOf('Savings Insights') >= 0 || nl.indexOf('Growth Projection') >= 0) break;
                  cardEnd++;
                }
                // Collect card lines
                var cardBody = cardLines.slice(cardStart + 2, cardEnd).filter(function(l){ return l && l.indexOf('──') < 0; });
                html += '<div class="rounded-xl border p-4 mb-3" style="border-color:' + fam.border + ';background:' + fam.bg + '">';
                html += '<div class="flex items-center gap-2 mb-2"><span>' + cIcon + '</span><span class="font-semibold text-sm text-gray-900">' + esc(cName) + '</span><span class="text-xs text-gray-400 ml-auto">' + esc(cCtx) + '</span></div>';
                for (var cli = 0; cli < cardBody.length; cli++) {
                  var bl = cardBody[cli];
                  if (bl.indexOf('Input:') >= 0 || bl.indexOf('Output:') >= 0) {
                    html += '<div class="text-xs text-gray-600 ml-5">' + esc(bl) + '</div>';
                  } else if (bl.indexOf('Per request:') >= 0 || bl.indexOf('Daily') >= 0 || bl.indexOf('Monthly') >= 0 || bl.indexOf('Annual') >= 0) {
                    html += '<div class="text-xs font-medium text-gray-800 ml-5">' + esc(bl) + '</div>';
                  } else if (bl.indexOf('Batch') >= 0 || bl.indexOf('Real-time') >= 0 || bl.indexOf('cache') >= 0 || bl.indexOf('reasoning') >= 0 || bl.indexOf('\u{1F9E0}') >= 0 || bl.indexOf('🧠') >= 0) {
                    html += '<div class="text-xs text-purple-700 ml-5 mt-1">' + esc(bl) + '</div>';
                  } else if (bl.trim()) {
                    html += '<div class="text-xs text-gray-500 ml-5">' + esc(bl) + '</div>';
                  }
                }
                html += '</div>';
                cardStart = cardEnd;
              } else {
                cardStart++;
              }
            }
            continue;
          }

          // --- Growth Projection Section ---
          if (s.indexOf('Growth Projection') >= 0) {
            var glines = s.split('\n');
            html += '<div class="mb-4">';
            html += '<h4 class="text-sm font-bold text-gray-800 mb-2">' + esc(glines[0]) + '</h4>';
            html += '<div class="overflow-x-auto"><table class="w-full text-xs border-collapse"><thead><tr class="bg-gray-100">';
            // Parse header row: "Month  │ ModelA      │ ModelB      │ Cum. Diff"
            var hdrParts = glines[2] ? glines[2].split('│') : [];
            for (var hi = 0; hi < hdrParts.length; hi++) {
              html += '<th class="px-2 py-1.5 text-left font-semibold text-gray-600">' + esc(hdrParts[hi].trim()) + '</th>';
            }
            html += '</tr></thead><tbody>';
            // Data rows start after separator
            for (var ri = 4; ri < glines.length; ri++) {
              if (!glines[ri] || glines[ri].indexOf('💡') >= 0) break;
              var cells = glines[ri].split('│');
              if (cells.length < 2) continue;
              html += '<tr class="border-t border-gray-100">';
              for (var ci = 0; ci < cells.length; ci++) {
                html += '<td class="px-2 py-1.5 text-gray-700">' + esc(cells[ci].trim()) + '</td>';
              }
              html += '</tr>';
            }
            // Summary line
            for (var ri2 = 4; ri2 < glines.length; ri2++) {
              if (glines[ri2] && glines[ri2].indexOf('💡') >= 0) {
                html += '<tr><td colspan="' + hdrParts.length + '" class="px-2 py-1.5 text-xs text-purple-700 font-medium">' + esc(glines[ri2].trim()) + '</td></tr>';
              }
            }
            html += '</tbody></table></div></div>';
            continue;
          }

          // --- Savings Insights Section ---
          if (s.indexOf('Savings Insights') >= 0) {
            var slines = s.split('\n').filter(function(l){ return l.trim() && l.indexOf('━━') < 0 && l.indexOf('Savings') < 0; });
            html += '<div class="rounded-xl border border-amber-200 bg-amber-50 p-4 mb-3">';
            html += '<h4 class="text-sm font-bold text-gray-800 mb-2">💰 Savings Insights</h4>';
            for (var sli = 0; sli < slines.length; sli++) {
              var sl = slines[sli].trim();
              if (sl.indexOf('🏆') >= 0) {
                html += '<div class="text-xs font-semibold text-green-700">' + esc(sl) + '</div>';
              } else if (sl.indexOf('⭐') >= 0) {
                html += '<div class="text-xs font-medium text-blue-700">' + esc(sl) + '</div>';
              } else if (sl.indexOf('💸') >= 0) {
                html += '<div class="text-xs text-purple-700 mt-0.5">' + esc(sl) + '</div>';
              } else if (sl.indexOf('🌍') >= 0 || sl.indexOf('🌐') >= 0) {
                html += '<div class="text-xs text-indigo-700 mt-0.5">' + esc(sl) + '</div>';
              } else if (sl.indexOf('💾') >= 0 || sl.indexOf('🗜️') >= 0) {
                html += '<div class="text-xs text-teal-700 mt-0.5">' + esc(sl) + '</div>';
              } else if (sl.trim()) {
                html += '<div class="text-xs text-gray-600 mt-0.5">' + esc(sl) + '</div>';
              }
            }
            html += '</div>';
            continue;
          }

          // --- Usage Scenarios Section ---
          if (s.indexOf('Usage Scenarios') >= 0) {
            var ulines = s.split('\n').filter(function(l){ return l.trim() && l.indexOf('━━') < 0 && l.indexOf('Usage') < 0; });
            html += '<div class="mb-3">';
            html += '<h4 class="text-sm font-bold text-gray-800 mb-2">📅 Usage Scenarios (monthly costs)</h4>';
            html += '<div class="space-y-1">';
            for (var uli = 0; uli < ulines.length; uli++) {
              var ul = ulines[uli].trim();
              if (!ul) continue;
              // Split: icon Name: 50→$X  ·  100→$Y  ·  ...
              var um = ul.match(/^([\u{1F535}\u{1F7E2}\u{1F7E0}⚪])\s+(.+?):\s+(.+)/u);
              if (um) {
                var uIcon = um[1];
                var uName = um[2];
                var uData = um[3];
                var uFam = familyColors[uIcon] || familyColors['⚪'];
                html += '<div class="flex items-center gap-2 text-xs py-1 px-2 rounded" style="background:' + uFam.bg + '">';
                html += '<span class="font-semibold text-gray-800 w-24 shrink-0">' + uIcon + ' ' + esc(uName) + '</span>';
                html += '<span class="text-gray-600">' + esc(uData).replace(/·/g, '<span class="text-gray-300 mx-1">·</span>') + '</span>';
                html += '</div>';
              }
            }
            html += '</div></div>';
            continue;
          }

          // --- Fallback: render as text block ---
          html += '<div class="text-xs text-gray-600 whitespace-pre-line">' + esc(s) + '</div>';
        }
        return html;
      }

      // Beautify Claude calculator text output into styled HTML sections
      function beautifyClaude(text) {
        // Apply generic bar beautifier first
        var html = beautifyBars(esc(text));

        // Claude family colors
        var FAMILY_COLORS = {
          '✦': '#7c3aed',  // ✦ mythos purple
          '▲': '#2563eb',   // ▲ claude4x blue
          '◆': '#6b7280',   // ◆ legacy gray
        };

        // Color family icons
        html = html.replace(/^(✦|▲|◆)/gm, function(match) {
          var color = FAMILY_COLORS[match] || '#6b7280';
          return '<span style="color:' + color + ';font-weight:bold">' + esc(match) + '</span>';
        });

        return html;
      }

      // Beautify DeepSeek calculator text output into styled HTML sections
      function beautifyDeepSeek(text) {
        // Apply generic bar beautifier first
        var html = beautifyBars(esc(text));

        // DeepSeek family colors
        var FAMILY_COLORS = {
          '◆': '#16a34a',  // v4 green
          '◇': '#9ca3af',  // legacy gray
        };

        // Color family icons
        html = html.replace(/^(◆|◇)/gm, function(match) {
          var color = FAMILY_COLORS[match] || '#9ca3af';
          return '<span style="color:' + color + ';font-weight:bold">' + esc(match) + '</span>';
        });

        return html;
      }

      // Beautify Gemini calculator text output into styled HTML sections
      function beautifyGemini(text) {
        // Apply generic bar beautifier first
        var html = beautifyBars(esc(text));

        // Gemini family colors
        var FAMILY_COLORS = {
          '●': '#22c55e',  // flash35 green
          '▲': '#3b82f6',   // pro blue
          '◆': '#14b8a6',   // flash3 teal
          '◇': '#9ca3af',   // legacy gray
        };

        // Color family icons
        html = html.replace(/^(●|▲|◆|◇)/gm, function(match) {
          var color = FAMILY_COLORS[match] || '#9ca3af';
          return '<span style="color:' + color + ';font-weight:bold">' + esc(match) + '</span>';
        });

        return html;
      }

      // Beautify AI API Cost Comparison text output into styled HTML sections
      function beautifyAiApiCostComparison(text) {
        var html = beautifyBars(esc(text));
        // Provider colors
        var provColors = {
          'O': '#10b981', // OpenAI green
          'A': '#7c3aed', // Anthropic purple
          'G': '#3b82f6', // Google blue
          'D': '#f59e0b', // DeepSeek amber
        };
        // Color [X] prefixes
        html = html.replace(/\[([OAGD])\]/g, function(m, initial) {
          var color = provColors[initial] || '#6b7280';
          return '<span style="color:' + color + ';font-weight:bold">[' + initial + ']</span>';
        });
        // Bold section headers
        html = html.replace(/^(\S.*)$/gm, function(line) {
          if (line.indexOf('🏆') >= 0 || line.indexOf('📊') >= 0 || line.indexOf('🔍') >= 0 || line.indexOf('📅') >= 0) {
            return '<span class="font-bold text-gray-800">' + line + '</span>';
          }
          return line;
        });
        return html;
      }

      // Beautify AI Image Cost Calculator text output into styled HTML sections
      function beautifyImage(text) {
        var html = beautifyBars(esc(text));
