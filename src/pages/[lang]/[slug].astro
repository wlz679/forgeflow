---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ResultCard from '../../components/ResultCard.astro';
import FAQ from '../../components/FAQ.astro';
import HowToUse from '../../components/HowToUse.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdUnit from '../../components/AdUnit.astro';
import '../../engines';
import { getEngine } from '../../core/engines/registry';
import { relatedTools } from '../../data/internal-links';
import { tools } from '../../data/tools';
import { t, getLang } from '../../i18n';

export function getStaticPaths() {
  const paths: { params: { lang: string; slug: string } }[] = [];
  for (const lang of ['en', 'zh']) {
    for (const tool of tools) {
      paths.push({ params: { lang, slug: tool.slug } });
    }
  }
  return paths;
}

const { slug, lang } = Astro.params;
const redirects: Record<string, string> = {
  'solopreneur-runway-calculator': 'solopreneur-burn-rate-calculator',
};
if (redirects[slug!]) return Astro.redirect(`/${lang}/${redirects[slug!]}`);

const engine = getEngine(slug!);
if (!engine) return Astro.redirect(`/${lang}/`);

const related = relatedTools[slug!]?.map(s => tools.find(t => t.slug === s)!).filter(Boolean) ?? [];
const toolTitle = t(`tools.${slug}.title`, lang);
const toolDescription = t(`tools.${slug}.description`, lang);
const metaTitle = `${toolTitle} — CalcKit`;
const isInteractive = engine.inputs.length > 0;
const clientConfig = JSON.stringify(engine.clientConfig);

const translatedFaq = engine.faq.map((item, i) => ({
  q: t(`tools.${slug}.faq.${i}.q`, lang),
  a: t(`tools.${slug}.faq.${i}.a`, lang),
}));
const translatedHowToUse = engine.howToUse.map((_, i) => t(`tools.${slug}.how_to_use.${i}`, lang));

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      mainEntity: translatedFaq.map(item => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
    {
      '@type': 'SoftwareApplication',
      name: toolTitle,
      applicationCategory: 'Multimedia',
      operatingSystem: 'Web',
      description: toolDescription,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: t('breadcrumb.home', lang), item: Astro.site?.toString() || '/' },
        { '@type': 'ListItem', position: 2, name: toolTitle },
      ],
    },
  ],
});
---

<BaseLayout title={metaTitle} description={toolDescription} schema={schema}>
  <Header />
  <main class="max-w-6xl mx-auto px-4 py-8 flex-1">
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href={`/${lang}/`} class="hover:text-[#7C3AED] transition-colors">{t('breadcrumb.home', lang)}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">{toolTitle}</span>
    </nav>

    <div class="lg:grid lg:grid-cols-5 lg:gap-10">
      <div class="lg:col-span-2">
        <div class="mb-6">
          <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 leading-tight">{toolTitle}</h1>
          <p class="text-sm text-gray-500 mt-2 leading-relaxed">{toolDescription}</p>
        </div>

        {isInteractive && (
          <form id="tool-form" class="mt-6 p-5 bg-white border border-gray-100 rounded-2xl shadow-sm">
            {/* OpenAI calculator: presets + token estimator + advanced collapse */}
            {slug === 'solopreneur-openai-token-calculator' ? (
              <>
                {/* Preset buttons */}
                <div class="mb-5">
                  <span class="block text-xs font-medium text-gray-400 mb-2 uppercase tracking-wide">{lang === 'zh' ? '🎭 场景预设' : '🎭 Scenario Presets'}</span>
                  <div class="flex flex-wrap gap-1.5" id="preset-buttons">
                    {[
                      { emoji:'🎧', en:'Support Bot', zh:'客服机器人', m:'gpt-5-mini', it:'800', ot:'200', rd:'500' },
                      { emoji:'📚', en:'RAG Q&A', zh:'RAG 问答', m:'gpt-4.1', it:'3000', ot:'400', rd:'200' },
                      { emoji:'💻', en:'Code Review', zh:'代码审查', m:'gpt-5.5', it:'5000', ot:'800', rd:'50' },
                      { emoji:'🌐', en:'Translation', zh:'文档翻译', m:'gpt-5', it:'2000', ot:'1500', rd:'100' },
                      { emoji:'✍️', en:'Content Gen', zh:'内容生成', m:'gpt-5.2', it:'500', ot:'2000', rd:'100' },
                      { emoji:'📊', en:'Data Analysis', zh:'数据分析', m:'o3', it:'4000', ot:'3000', rd:'30' },
                    ].map(p => (
                      <button type="button" class="preset-btn text-xs px-2.5 py-1.5 rounded-lg border border-gray-200 bg-gray-50 hover:border-[#7C3AED] hover:bg-[#7C3AED]/5 transition-all" data-models={p.m} data-it={p.it} data-ot={p.ot} data-rd={p.rd}>{p.emoji} {lang === 'zh' ? p.zh : p.en}</button>
                    ))}
                  </div>
                </div>

                {/* Token estimator */}
                <div class="mb-5">
                  <span class="block text-xs font-medium text-gray-400 mb-2 uppercase tracking-wide">{lang === 'zh' ? '📝 Token 估算器' : '📝 Token Estimator'}</span>
                  <textarea id="token-estimator" rows="3" placeholder={lang === 'zh' ? '粘贴你的提示文本...' : 'Paste your prompt text...'} class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all resize-none"></textarea>
                  <div id="token-estimate-result" class="text-xs text-gray-400 mt-1.5 hidden">
                    {lang === 'zh' ? '估算：输入 ~<span id="est-tokens">0</span> tokens' : 'Estimated: ~<span id="est-tokens">0</span> input tokens'}
                  </div>
                </div>

                {/* Core inputs: first 4 */}
                {engine.inputs.slice(0, 4).map(input => (
                  input.type === 'select' ? (
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                      <select id={input.name} name={input.name} class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 bg-white transition-all">
                        <option value="">{t('form.select', lang)}</option>
                        {input.options?.map(opt => <option value={opt}>{opt}</option>)}
                      </select>
                    </div>
                  ) : (
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                      <input type={input.type} id={input.name} name={input.name} placeholder={t(`tools.${slug}.input.${input.name}.placeholder`, lang)} value={input.name === 'models' ? 'gpt-5-mini,gpt-5.5,gpt-4.1' : ''} class="w-full pl-4 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all" />
                    </div>
                  )
                ))}

                {/* Advanced options: collapsed */}
                <details class="mb-4 group" id="advanced-options">
                  <summary class="text-xs font-medium text-gray-400 cursor-pointer hover:text-[#7C3AED] transition-colors select-none py-1">
                    {lang === 'zh' ? '⚙️ 高级选项' : '⚙️ Advanced Options'}
                  </summary>
                  <div class="mt-3 pt-3 border-t border-gray-100 space-y-0">
                    {engine.inputs.slice(4).map(input => (
                      input.type === 'select' ? (
                        <div class="mb-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                          <select id={input.name} name={input.name} class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 bg-white transition-all">
                            <option value="">{t('form.select', lang)}</option>
                            {input.options?.map(opt => <option value={opt} selected={opt === 'realtime'}>{opt}</option>)}
                          </select>
                        </div>
                      ) : (
                        <div class="mb-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                          <input type={input.type} id={input.name} name={input.name} placeholder={t(`tools.${slug}.input.${input.name}.placeholder`, lang)} class="w-full pl-4 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all" />
                        </div>
                      )
                    ))}
                  </div>
                </details>

                {/* Model hint */}
                <div class="mb-4 -mt-2">
                  <span class="text-xs text-gray-400">{lang === 'zh' ? '可用模型：' : 'Available: '}gpt-5.5, gpt-5.2, gpt-5, gpt-5-mini, gpt-5-nano, gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, o3, o4-mini, gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo</span>
                </div>
              </>
            ) : (
              engine.inputs.map(input => (
                input.type === 'select' ? (
                  <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                    <select id={input.name} name={input.name} class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 bg-white transition-all">
                      <option value="">{t('form.select', lang)}</option>
                      {input.options?.map(opt => <option value={opt}>{opt}</option>)}
                    </select>
                  </div>
                ) : (
                  <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                    <input type={input.type} id={input.name} name={input.name} placeholder={t(`tools.${slug}.input.${input.name}.placeholder`, lang)} class="w-full pl-4 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all" />
                  </div>
                )
              ))
            )}
            <button type="submit" class="w-full py-3.5 bg-gradient-to-r from-[#7C3AED] to-[#6D28D9] text-white font-semibold rounded-xl hover:shadow-lg hover:shadow-[#7C3AED]/25 transition-all text-sm">
              {t('btn.generate', lang)}
            </button>
          </form>
        )}

        <HowToUse steps={translatedHowToUse} />
        <FAQ items={translatedFaq} />
      </div>

      <div class="lg:col-span-3 mt-8 lg:mt-0" id="results-section">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900">{t('results.title', lang)}</h2>
          <span id="copy-all" class="text-xs font-medium cursor-pointer select-none hidden px-3 py-1.5 bg-gray-100 hover:bg-[#7C3AED] hover:text-white rounded-full transition-all" data-copy-all-label={t('btn.copy_all', lang)} data-copied-label={t('btn.copied', lang)}>{t('btn.copy_all', lang)}</span>
        </div>

        <span class="inline-block text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full mb-3" id="example-badge">{t('results.example', lang)}</span>
        <div id="static-results" class="space-y-3">
          {(engine.clientConfig.type === 'custom'
            ? [engine.staticExamples[0]]
            : engine.staticExamples
          ).map((ex, i) => (
            <ResultCard text={ex} index={i} hideIndex={engine.clientConfig.type === 'custom'} />
          ))}
        </div>

        <div id="dynamic-results" class="space-y-3 hidden"></div>
        <AdUnit slot="tool-result" />
        <RelatedTools tools={related.map(r => ({ slug: r.slug, title: t(`tools.${r.slug}.title`, lang) }))} />
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

{isInteractive && (
  <>
    <script define:vars={{ clientConfig, exportLabel: t('btn.export', lang) }}>
      function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
      function fill(t, v) { return t.replace(/\{(\w+)\}/g, function(_, k) { return v[k] ?? '{' + k + '}'; }); }
      function generateFromConfig(config, inputs) {
        if (config.type === 'custom' && config.customFn) {
          var fn = new Function('inputs', 'pick', 'fill', config.customFn);
          return fn(inputs, pick, fill);
        }
        var count = 10;
        var v = { topic: inputs.topic || inputs.niche || inputs.keyword || inputs.interest || inputs.title || 'your topic', niche: inputs.niche || inputs.topic || 'your niche', keyword: inputs.keyword || inputs.topic || 'your keyword' };
        var results = [];
        var seen = {};
        var attempts = 0;
        while (results.length < count && attempts < count * 15) {
          attempts++;
          for (var key in config.wordPools) v[key] = pick(config.wordPools[key]);
          var result = '';
          if (config.type === 'templates') result = fill(pick(config.templates), v).trim();
          else if (config.type === 'combinations') result = pick(config.patterns)(v).trim();
          if (result && !seen[result]) { seen[result] = true; results.push(result); }
        }
        return results;
      }

      function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function escAttr(s) { return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;'); }
var copyLabel = document.getElementById('copy-all')?.dataset.copyAllLabel || 'Copy All';
      var copiedLabel = document.getElementById('copy-all')?.dataset.copiedLabel || 'Copied!';

      var form = document.getElementById('tool-form');
      var config = JSON.parse(clientConfig);
      var dynamicResults = document.getElementById('dynamic-results');
      var staticResults = document.getElementById('static-results');
      var copyAllBtn = document.getElementById('copy-all');

      // --- Preset buttons ---
      var presetBtns = document.querySelectorAll('.preset-btn');
      presetBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var modelsEl = document.getElementById('models');
          var itEl = document.getElementById('inputTokens');
          var otEl = document.getElementById('outputTokens');
          var rdEl = document.getElementById('requestsPerDay');
          if (modelsEl) modelsEl.value = this.dataset.models;
          if (itEl) itEl.value = this.dataset.it;
          if (otEl) otEl.value = this.dataset.ot;
          if (rdEl) rdEl.value = this.dataset.rd;
        });
      });

      // --- Token estimator ---
      var estimatorEl = document.getElementById('token-estimator');
      var estResultEl = document.getElementById('token-estimate-result');
      var estTokensEl = document.getElementById('est-tokens');
      if (estimatorEl && estResultEl && estTokensEl) {
        estimatorEl.addEventListener('input', function() {
          var text = this.value;
          if (!text.trim()) { estResultEl.classList.add('hidden'); return; }
          var cjk = 0, other = 0;
          for (var i = 0; i < text.length; i++) {
            var code = text.charCodeAt(i);
            if ((code >= 0x4e00 && code <= 0x9fff) || (code >= 0x3400 && code <= 0x4dbf) ||
                (code >= 0x3040 && code <= 0x309f) || (code >= 0x30a0 && code <= 0x30ff) ||
                (code >= 0xac00 && code <= 0xd7af)) { cjk++; }
            else if (text[i].trim()) { other++; }
          }
          var tokens = Math.ceil(cjk / 1.5 + other / 4);
          estTokensEl.textContent = tokens.toLocaleString();
          estResultEl.classList.remove('hidden');
          // Auto-fill inputTokens
          var itEl = document.getElementById('inputTokens');
          if (itEl && !itEl.value) itEl.value = tokens;
        });
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var fd = new FormData(form);
        var inputs = {};
        fd.forEach(function(v, k) { inputs[k] = v.toString(); });
        var results = generateFromConfig(config, inputs);
        var exportResult = config.type === 'custom' ? results[0] : results.join('\n\n');
        if (config.type === 'custom') { results = [results[0]]; }

        var html = '';
        for (var i = 0; i < results.length; i++) {
          var r = results[i];
          if (r.indexOf(' → ') > -1 && r.indexOf(' | ') > -1) {
            var dims = r.split(' | ');
            html += '<div class="analysis-card group p-4 bg-white border border-gray-100 rounded-xl hover:border-[#7C3AED]/30 transition-all duration-300">';
            html += '<div class="flex items-start justify-between gap-3 mb-2"><span class="text-xs font-bold text-gray-400 shrink-0 pt-0.5 w-5">#' + (i+1) + '</span>';
            html += '<div class="flex-1"><div class="text-sm text-gray-800 font-medium leading-relaxed">' + esc(dims[0]) + '</div></div>';
            html += '<button type="button" class="expand-btn inline-flex items-center gap-1 text-xs text-[#7C3AED] font-medium px-2 py-1.5 rounded-lg hover:bg-[#7C3AED]/10 transition-all shrink-0"><span class="exp-label">查看详情</span><svg class="w-3 h-3 exp-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></button></div>';
            html += '<div class="detail hidden mt-3 pt-3 border-t border-gray-100 space-y-2">';
            for (var d = 1; d < dims.length; d++) { var kv = dims[d].split(' → '); html += '<div class="flex gap-2 text-sm"><span class="text-gray-400 shrink-0 font-medium">' + esc(kv[0]) + '</span><span class="text-gray-700">' + esc(kv.slice(1).join(' → ')) + '</span></div>'; }
            html += '</div></div>';
          } else if (config.type === 'custom' && results.length === 1) {
            // Calculator single result — structured dashboard card, no index
            var lines = r.split('\n').filter(function(l) { return l.indexOf('💡 Tip:') === -1; });
            var titleLine = lines[0];
            var restLines = lines.slice(1).join('\n');
            var strippedR = lines.join('\n');
            html += '<div class="group bg-white border border-gray-100 rounded-2xl overflow-hidden hover:border-[#7C3AED]/30 transition-all duration-300">';
            html += '<div class="flex items-start justify-between gap-3 p-5 pb-3 border-b border-gray-50">';
            html += '<h3 class="text-base font-bold text-gray-900">' + esc(titleLine) + '</h3>';
            html += '<div class="flex items-center gap-0.5 opacity-0 group-hover:opacity-100 transition-opacity duration-200">';
            html += '<button type="button" class="copy-btn inline-flex items-center gap-1 text-xs text-gray-400 hover:text-[#7C3AED] font-medium px-2 py-1.5 rounded-lg hover:bg-gray-50 transition-all shrink-0" data-copy="' + escAttr(strippedR) + '"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg></button>';
            html += '<button type="button" class="export-btn inline-flex items-center gap-1 text-xs text-gray-400 hover:text-[#059669] font-medium px-2 py-1.5 rounded-lg hover:bg-gray-50 transition-all shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg><span>' + exportLabel + '</span></button>';
            html += '</div></div>';
            html += '<div class="p-5 bg-gray-50/50 text-sm text-gray-700 leading-relaxed whitespace-pre-line font-mono">' + esc(restLines) + '</div>';
            html += '</div>';
          } else {
            var strippedR2 = r.split('\n').filter(function(l) { return l.indexOf('💡 Tip:') === -1; }).join('\n');
            html += '<div class="group flex items-start justify-between gap-4 p-4 bg-white border border-gray-100 rounded-xl hover:border-[#7C3AED]/30 transition-all duration-300"><span class="text-xs font-bold text-gray-400 shrink-0 pt-0.5 w-5">#' + (i+1) + '</span>';
            html += '<span class="text-sm text-gray-700 flex-1 leading-relaxed whitespace-pre-line">' + esc(strippedR2) + '</span>';
            html += '<button type="button" class="copy-btn opacity-0 group-hover:opacity-100 inline-flex items-center gap-1 text-xs text-gray-400 hover:text-[#7C3AED] font-medium px-2 py-1.5 rounded-lg hover:bg-gray-50 transition-all shrink-0" data-copy="' + escAttr(strippedR2) + '"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg></button></div>';
          }
        }
        dynamicResults.innerHTML = html;
        dynamicResults.classList.remove('hidden');
        staticResults.classList.add('hidden');
        copyAllBtn.classList.remove('hidden');
        var badge = document.getElementById('example-badge');
        if (badge) badge.classList.add('hidden');

        dynamicResults.querySelectorAll('.expand-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var detail = this.closest('.analysis-card').querySelector('.detail');
            var icon = this.querySelector('.exp-icon');
            var label = this.querySelector('.exp-label');
            var hidden = detail.classList.contains('hidden');
            detail.classList.toggle('hidden');
            icon.style.transform = hidden ? 'rotate(180deg)' : '';
            label.textContent = hidden ? '收起' : '查看详情';
          });
        });
        dynamicResults.querySelectorAll('.copy-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            navigator.clipboard.writeText(this.dataset.copy).then(function() {
              var t = this; t.style.color = '#059669';
              setTimeout(function() { t.style.color = ''; }, 1500);
            }.bind(this));
          });
        });
        var exportBtns = dynamicResults.querySelectorAll('.export-btn');
        if (exportBtns.length > 0) {
          exportBtns.forEach(function(btn) {
            btn.addEventListener('click', function() {
              var lines = [];
              lines.push('CalcKit — ' + (document.querySelector('h1')?.textContent || 'Calculator'));
              lines.push('Generated: ' + new Date().toLocaleString());
              lines.push('');
              lines.push('INPUTS');
              lines.push('------');
              var fields = form.querySelectorAll('input, select');
              fields.forEach(function(f) {
                var label = document.querySelector('label[for="' + f.id + '"]');
                var labelText = label ? label.textContent.trim() : f.name;
                lines.push(labelText + ': ' + (f.value || '(empty)'));
              });
              lines.push('');
              lines.push('RESULTS');
              lines.push('-------');
              lines.push(exportResult);
              var blob = new Blob([lines.join('\n')], { type: 'text/plain' });
              var a = document.createElement('a');
              a.href = URL.createObjectURL(blob);
              a.download = 'calckit-result-' + new Date().toISOString().slice(0, 10) + '.txt';
              a.click();
              URL.revokeObjectURL(a.href);
              var t = this;
              t.style.color = '#059669';
              setTimeout(function() { t.style.color = ''; }, 1500);
            });
          });
        }
      });

      copyAllBtn.addEventListener('click', function() {
        var cards = dynamicResults.querySelectorAll('.analysis-card,.group');
        var texts = [];
        cards.forEach(function(c) {
          var d = c.querySelector('.detail');
          if (d && !d.classList.contains('hidden')) {
            d.querySelectorAll('div').forEach(function(div) { texts.push(div.textContent); });
          } else {
            var span = c.querySelector('.text-gray-700,.text-gray-800');
            if (span) texts.push(span.textContent);
          }
        });
        if (texts.length === 0) {
          staticResults.querySelectorAll('.analysis-card,.group').forEach(function(c) {
            var span = c.querySelector('.text-gray-700,.text-gray-800');
            if (span) texts.push(span.textContent);
          });
        }
        navigator.clipboard.writeText(texts.join('\n\n')).then(function() {
          copyAllBtn.textContent = copiedLabel;
          setTimeout(function() { copyAllBtn.textContent = copyLabel; }, 2000);
        });
      });
    </script>
  </>
)}