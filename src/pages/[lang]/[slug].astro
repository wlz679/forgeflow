---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ResultCard from '../../components/ResultCard.astro';
import FAQ from '../../components/FAQ.astro';
import HowToUse from '../../components/HowToUse.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdUnit from '../../components/AdUnit.astro';
import '../../engines';
import { getEngine } from '../../core/engines/registry';
import { relatedTools } from '../../data/internal-links';
import { tools } from '../../data/tools';
import { t, getLang } from '../../i18n';

export function getStaticPaths() {
  const paths: { params: { lang: string; slug: string } }[] = [];
  for (const lang of ['en', 'zh']) {
    for (const tool of tools) {
      paths.push({ params: { lang, slug: tool.slug } });
    }
  }
  return paths;
}

const { slug, lang } = Astro.params;
const redirects: Record<string, string> = {
  'solopreneur-runway-calculator': 'solopreneur-burn-rate-calculator',
};
if (redirects[slug!]) return Astro.redirect(`/${lang}/${redirects[slug!]}`);

const engine = getEngine(slug!);
if (!engine) return Astro.redirect(`/${lang}/`);

const related = relatedTools[slug!]?.map(s => tools.find(t => t.slug === s)!).filter(Boolean) ?? [];
const toolTitle = t(`tools.${slug}.title`, lang);
const toolDescription = t(`tools.${slug}.description`, lang);
const metaTitle = `${toolTitle} — CalcKit`;
const isInteractive = engine.inputs.length > 0;
const isClaude = slug === 'solopreneur-claude-api-cost-calculator';
const isDeepSeek = slug === 'solopreneur-deepseek-api-cost-calculator';
const isGemini = slug === 'solopreneur-gemini-api-cost-calculator';
const isAiApiCostComparison = slug === 'solopreneur-ai-api-cost-comparison';
const isImage = slug === 'solopreneur-ai-image-cost-calculator';
const isTraining = slug === 'solopreneur-ai-training-cost-estimator';
const isGpu = slug === 'solopreneur-gpu-cloud-cost-calculator';
const clientConfig = JSON.stringify(engine.clientConfig);

const translatedFaq = engine.faq.map((item, i) => ({
  q: t(`tools.${slug}.faq.${i}.q`, lang),
  a: t(`tools.${slug}.faq.${i}.a`, lang),
}));
const translatedHowToUse = engine.howToUse.map((_, i) => t(`tools.${slug}.how_to_use.${i}`, lang));

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      mainEntity: translatedFaq.map(item => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
    {
      '@type': 'SoftwareApplication',
      name: toolTitle,
      applicationCategory: 'Multimedia',
      operatingSystem: 'Web',
      description: toolDescription,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: t('breadcrumb.home', lang), item: Astro.site?.toString() || '/' },
        { '@type': 'ListItem', position: 2, name: toolTitle },
      ],
    },
  ],
});
---

<BaseLayout title={metaTitle} description={toolDescription} schema={schema}>
  <Header />
  <main class="max-w-6xl mx-auto px-4 py-8 flex-1">
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href={`/${lang}/`} class="hover:text-[#7C3AED] transition-colors">{t('breadcrumb.home', lang)}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">{toolTitle}</span>
    </nav>

    <div class="lg:grid lg:grid-cols-5 lg:gap-10">
      <div class="lg:col-span-2">
        <div class="mb-6">
          <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 leading-tight">{toolTitle}</h1>
          <p class="text-sm text-gray-500 mt-2 leading-relaxed">{toolDescription}</p>
        </div>

        {isInteractive && (
          <form id="tool-form" class="mt-6 p-5 bg-white border border-gray-100 rounded-2xl shadow-sm">
            {/* OpenAI calculator: presets + token estimator + advanced collapse */}
            {slug === 'solopreneur-openai-token-calculator' ? (
              <>
                {/* Preset buttons */}
                <div class="mb-5">
                  <span class="block text-xs font-medium text-gray-400 mb-2 uppercase tracking-wide">{lang === 'zh' ? '🎭 场景预设' : '🎭 Scenario Presets'}</span>
                  <div class="flex flex-wrap gap-1.5" id="preset-buttons">
                    {[
                      { emoji:'🎧', en:'Support Bot', zh:'客服机器人', m:'gpt-5-mini', it:'800', ot:'200', rd:'500' },
                      { emoji:'📚', en:'RAG Q&A', zh:'RAG 问答', m:'gpt-4.1', it:'3000', ot:'400', rd:'200' },
                      { emoji:'💻', en:'Code Review', zh:'代码审查', m:'gpt-5.5', it:'5000', ot:'800', rd:'50' },
                      { emoji:'🌐', en:'Translation', zh:'文档翻译', m:'gpt-5', it:'2000', ot:'1500', rd:'100' },
                      { emoji:'✍️', en:'Content Gen', zh:'内容生成', m:'gpt-5.2', it:'500', ot:'2000', rd:'100' },
                      { emoji:'📊', en:'Data Analysis', zh:'数据分析', m:'o3', it:'4000', ot:'3000', rd:'30' },
                    ].map(p => (
                      <button type="button" class="preset-btn text-xs px-2.5 py-1.5 rounded-lg border border-gray-200 bg-gray-50 hover:border-[#7C3AED] hover:bg-[#7C3AED]/5 transition-all" data-models={p.m} data-it={p.it} data-ot={p.ot} data-rd={p.rd}>{p.emoji} {lang === 'zh' ? p.zh : p.en}</button>
                    ))}
                  </div>
                </div>

                {/* Token estimator */}
                <div class="mb-5">
                  <span class="block text-xs font-medium text-gray-400 mb-2 uppercase tracking-wide">{lang === 'zh' ? '📝 Token 估算器' : '📝 Token Estimator'}</span>
                  <textarea id="token-estimator" rows="3" placeholder={lang === 'zh' ? '粘贴你的提示文本...' : 'Paste your prompt text...'} class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all resize-none"></textarea>
                  <div id="token-estimate-result" class="text-xs text-gray-400 mt-1.5 hidden">
                    {lang === 'zh' ? '估算：输入 ~<span id="est-tokens">0</span> tokens' : 'Estimated: ~<span id="est-tokens">0</span> input tokens'}
                  </div>
                </div>

                {/* Core inputs: first 4 */}
                {engine.inputs.slice(0, 4).map(input => (
                  input.type === 'select' ? (
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                      <select id={input.name} name={input.name} class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 bg-white transition-all">
                        <option value="">{t('form.select', lang)}</option>
                        {input.options?.map(opt => <option value={opt}>{opt}</option>)}
                      </select>
                    </div>
                  ) : (
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                      <input type={input.type} id={input.name} name={input.name} placeholder={t(`tools.${slug}.input.${input.name}.placeholder`, lang)} value={input.name === 'models' ? 'gpt-5-mini,gpt-5.5,gpt-4.1' : ''} class="w-full pl-4 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all" />
                    </div>
                  )
                ))}

                {/* Advanced options: collapsed */}
                <details class="mb-4 group" id="advanced-options">
                  <summary class="text-xs font-medium text-gray-400 cursor-pointer hover:text-[#7C3AED] transition-colors select-none py-1">
                    {lang === 'zh' ? '⚙️ 高级选项' : '⚙️ Advanced Options'}
                  </summary>
                  <div class="mt-3 pt-3 border-t border-gray-100 space-y-0">
                    {engine.inputs.slice(4).map(input => (
                      input.type === 'select' ? (
                        <div class="mb-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                          <select id={input.name} name={input.name} class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 bg-white transition-all">
                            <option value="">{t('form.select', lang)}</option>
                            {input.options?.map(opt => <option value={opt} selected={opt === 'realtime'}>{opt}</option>)}
                          </select>
                        </div>
                      ) : (
                        <div class="mb-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                          <input type={input.type} id={input.name} name={input.name} placeholder={t(`tools.${slug}.input.${input.name}.placeholder`, lang)} class="w-full pl-4 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all" />
                        </div>
                      )
                    ))}
                  </div>
                </details>

                {/* Model hint */}
                <div class="mb-4 -mt-2">
                  <span class="text-xs text-gray-400">{lang === 'zh' ? '可用模型：' : 'Available: '}gpt-5.5, gpt-5.2, gpt-5, gpt-5-mini, gpt-5-nano, gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, o3, o4-mini, gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo</span>
                </div>
              </>
            ) : (
              engine.inputs.map(input => (
                input.type === 'select' ? (
                  <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                    <select id={input.name} name={input.name} class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 bg-white transition-all">
                      <option value="">{t('form.select', lang)}</option>
                      {input.options?.map(opt => <option value={opt}>{opt}</option>)}
                    </select>
                  </div>
                ) : (
                  <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                    <input type={input.type} id={input.name} name={input.name} placeholder={t(`tools.${slug}.input.${input.name}.placeholder`, lang)} class="w-full pl-4 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all" />
                  </div>
                )
              ))
            )}
            {isClaude && (
              <div class="flex flex-wrap gap-2 mt-3">
                <span class="text-sm text-gray-500 mr-1">{t('common.scenarios', lang)}:</span>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="500" data-outputtokens="1000" data-reqsperday="50"
                  data-pricingmode="realtime" data-cachewritetokens="500" data-cachettl="5min" data-cachehitrate="80"
                  data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-claude-api-cost-calculator.preset.small', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="2000" data-outputtokens="1000" data-reqsperday="500"
                  data-pricingmode="realtime" data-cachewritetokens="2000" data-cachettl="5min" data-cachehitrate="60"
                  data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-claude-api-cost-calculator.preset.mid', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="5000" data-outputtokens="2000" data-reqsperday="5000"
                  data-pricingmode="realtime" data-cachewritetokens="5000" data-cachettl="1hour" data-cachehitrate="40"
                  data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-claude-api-cost-calculator.preset.high', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="3000" data-outputtokens="5000" data-reqsperday="10000"
                  data-pricingmode="batch" data-cachewritetokens="0" data-cachettl="5min" data-cachehitrate="0"
                  data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-claude-api-cost-calculator.preset.batch', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="2000" data-outputtokens="800" data-reqsperday="2000"
                  data-pricingmode="realtime" data-cachewritetokens="2000" data-cachettl="1hour" data-cachehitrate="90"
                  data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-claude-api-cost-calculator.preset.cache', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="10000" data-outputtokens="5000" data-reqsperday="50000"
                  data-pricingmode="batch" data-cachewritetokens="10000" data-cachettl="1hour" data-cachehitrate="70"
                  data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-claude-api-cost-calculator.preset.enterprise', lang)}
                </button>
              </div>
            )}
            {isDeepSeek && (
              <div class="flex flex-wrap gap-2 mt-3">
                <span class="text-sm text-gray-500 mr-1">Quick Scenarios:</span>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="500" data-outputtokens="1000" data-reqsperday="50" data-cachehitrate="80" data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-deepseek-api-cost-calculator.preset.light', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="2000" data-outputtokens="1000" data-reqsperday="500" data-cachehitrate="60" data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-deepseek-api-cost-calculator.preset.mid', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="5000" data-outputtokens="2000" data-reqsperday="10000" data-cachehitrate="50" data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-deepseek-api-cost-calculator.preset.high', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="2000" data-outputtokens="800" data-reqsperday="5000" data-cachehitrate="95" data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-deepseek-api-cost-calculator.preset.cache', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="1000" data-outputtokens="800" data-reqsperday="200" data-cachehitrate="70" data-growthrate="10" data-projectionmonths="12">
                  {t('tools.solopreneur-deepseek-api-cost-calculator.preset.growing', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="8000" data-outputtokens="5000" data-reqsperday="100000" data-cachehitrate="60" data-growthrate="0" data-projectionmonths="6">
                  {t('tools.solopreneur-deepseek-api-cost-calculator.preset.enterprise', lang)}
                </button>
              </div>
            )}
            {isGemini && (
              <div class="flex flex-wrap gap-2 mt-3">
                <span class="text-sm text-gray-500 mr-1">Quick Scenarios:</span>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="500" data-outputtokens="1000" data-reqsperday="50" data-pricingmode="realtime" data-cachehitrate="80" data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-gemini-api-cost-calculator.preset.light', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="2000" data-outputtokens="1000" data-reqsperday="500" data-pricingmode="realtime" data-cachehitrate="60" data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-gemini-api-cost-calculator.preset.mid', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="5000" data-outputtokens="2000" data-reqsperday="10000" data-pricingmode="realtime" data-cachehitrate="50" data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-gemini-api-cost-calculator.preset.high', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="3000" data-outputtokens="5000" data-reqsperday="10000" data-pricingmode="batch" data-cachehitrate="0" data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-gemini-api-cost-calculator.preset.batch', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="2000" data-outputtokens="800" data-reqsperday="5000" data-pricingmode="realtime" data-cachehitrate="95" data-growthrate="0" data-projectionmonths="12">
                  {t('tools.solopreneur-gemini-api-cost-calculator.preset.cache', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="8000" data-outputtokens="5000" data-reqsperday="100000" data-pricingmode="realtime" data-cachehitrate="60" data-growthrate="0" data-projectionmonths="6">
                  {t('tools.solopreneur-gemini-api-cost-calculator.preset.enterprise', lang)}
                </button>
              </div>
            )}
            {isAiApiCostComparison && (
              <div class="flex flex-wrap gap-2 mt-3">
                <span class="text-sm text-gray-500 mr-1">{lang === 'zh' ? '场景预设：' : 'Scenarios:'}</span>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="800" data-outputtokens="200" data-requestsperday="500" data-pricingmode="realtime">
                  {t('tools.solopreneur-ai-api-cost-comparison.preset.support-bot', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="3000" data-outputtokens="400" data-requestsperday="200" data-pricingmode="realtime">
                  {t('tools.solopreneur-ai-api-cost-comparison.preset.rag-qa', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="5000" data-outputtokens="800" data-requestsperday="50" data-pricingmode="realtime">
                  {t('tools.solopreneur-ai-api-cost-comparison.preset.code-review', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="500" data-outputtokens="2000" data-requestsperday="100" data-pricingmode="realtime">
                  {t('tools.solopreneur-ai-api-cost-comparison.preset.content-gen', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="4000" data-outputtokens="3000" data-requestsperday="30" data-pricingmode="realtime">
                  {t('tools.solopreneur-ai-api-cost-comparison.preset.data-analysis', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-inputtokens="3000" data-outputtokens="5000" data-requestsperday="10000" data-pricingmode="batch">
                  {t('tools.solopreneur-ai-api-cost-comparison.preset.batch', lang)}
                </button>
              </div>
            )}
            {isImage && (
              <div class="flex flex-wrap gap-2 mt-3">
                <span class="text-sm text-gray-500 mr-1">{lang === 'zh' ? '场景预设：' : 'Scenarios:'}</span>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-provider="dalle-3" data-imagespermonth="100" data-resolution="1024×1024" data-batchsize="1" data-advancedmode="standard">
                  {t('tools.solopreneur-ai-image-cost-calculator.preset.solopreneur', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-provider="midjourney-v7" data-imagespermonth="500" data-resolution="2048×2048" data-batchsize="4" data-advancedmode="standard">
                  {t('tools.solopreneur-ai-image-cost-calculator.preset.creator', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-provider="dalle-4" data-imagespermonth="1000" data-resolution="1024×1024" data-batchsize="4" data-advancedmode="hd">
                  {t('tools.solopreneur-ai-image-cost-calculator.preset.agency', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-provider="stable-diffusion-4" data-imagespermonth="5000" data-resolution="512×512" data-batchsize="8" data-advancedmode="standard">
                  {t('tools.solopreneur-ai-image-cost-calculator.preset.budget', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-provider="ideogram-3" data-imagespermonth="300" data-resolution="1024×1024" data-batchsize="2" data-advancedmode="standard">
                  {t('tools.solopreneur-ai-image-cost-calculator.preset.logos', lang)}
                </button>
                <button type="button" class="preset-chip text-xs px-3 py-1.5 rounded-full border hover:bg-gray-100 transition"
                  data-provider="flux-pro" data-imagespermonth="800" data-resolution="2048×2048" data-batchsize="2" data-advancedmode="hd">
