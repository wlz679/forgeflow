      // Helper: render a detail card for one model/provider
      function renderCard(card, content, config) {
        var fam = config.families[card.icon] || config.defaultFamily;
        var nameMatch = card.raw.match(/^\S\s+(.+?)\s*[\(|]/);
        var name = nameMatch ? nameMatch[1].trim() : card.raw;
        var famMatch = card.raw.match(/\((.+?)\)/);
        var famLabel = famMatch ? famMatch[1] : '';
        var ctxMatch = card.raw.match(/\|\s*Context:\s*(.+)/);
        var ctxLabel = ctxMatch ? ctxMatch[1] : '';

        var h = '';
        h += '<div class="rounded-xl border p-4" style="border-color:' + fam.border + ';background:' + fam.bg + '">';
        h += '<div class="flex items-center gap-2 mb-2">';
        h += '<span style="color:' + (fam.text || fam.bar) + ';font-weight:bold">' + esc(card.icon) + '</span>';
        h += '<span class="font-semibold text-sm text-gray-900">' + esc(name) + '</span>';
        if (famLabel || ctxLabel) {
          h += '<span class="text-xs text-gray-400 ml-auto">' + esc(famLabel || ctxLabel) + '</span>';
        }
        h += '</div>';

        for (var i = 0; i < content.length; i++) {
          var l = content[i].trim();
          if (!l) continue;
          if (l.indexOf('Context:') >= 0 || l.indexOf('Rate:') >= 0) {
            h += '<div class="text-xs text-gray-500 ml-5">' + esc(l) + '</div>';
          } else if (l.indexOf('Per Request:') >= 0 || l.indexOf('Per request:') >= 0 || l.indexOf('Monthly Cost') >= 0 || l.indexOf('Monthly:') >= 0 || l.indexOf('Annual') >= 0 || l.indexOf('Daily') >= 0) {
            h += '<div class="text-xs font-semibold text-gray-800 ml-5 mt-0.5">' + esc(l) + '</div>';
          } else if (l.indexOf('💾') >= 0 || l.indexOf('cache') >= 0 || l.indexOf('With caching') >= 0) {
            h += '<div class="text-xs text-emerald-700 ml-5 mt-0.5 font-medium">' + esc(l) + '</div>';
          } else if (l.indexOf('Batch') >= 0 || l.indexOf('Real-time') >= 0 || l.indexOf('reasoning') >= 0 || l.indexOf('🧠') >= 0) {
            h += '<div class="text-xs text-blue-700 ml-5 mt-0.5">' + esc(l) + '</div>';
          } else if (l.trim()) {
            h += '<div class="text-xs text-gray-600 ml-5">' + esc(l) + '</div>';
          }
        }
        h += '</div>';
        return h;
      }

      // ===== Calculator configs — 8 compact objects, one per calculator =====

      // OpenAI family config
      var OPENAI_CONFIG = {
        families: {
          '🔵': { bg: '#eff6ff', bar: '#3b82f6', border: '#bfdbfe', text: '#3b82f6' },
          '🟢': { bg: '#f0fdf4', bar: '#22c55e', border: '#bbf7d0', text: '#22c55e' },
