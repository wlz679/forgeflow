---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ResultCard from '../../components/ResultCard.astro';
import FAQ from '../../components/FAQ.astro';
import HowToUse from '../../components/HowToUse.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdUnit from '../../components/AdUnit.astro';
import '../../engines';
import { getEngine } from '../../core/engines/registry';
import { relatedTools } from '../../data/internal-links';
import { tools } from '../../data/tools';
import { t, getLang } from '../../i18n';

export function getStaticPaths() {
  const paths: { params: { lang: string; slug: string } }[] = [];
  for (const lang of ['en', 'zh']) {
    for (const tool of tools) {
      paths.push({ params: { lang, slug: tool.slug } });
    }
  }
  return paths;
}

const { slug, lang } = Astro.params;
const redirects: Record<string, string> = {
  'solopreneur-runway-calculator': 'solopreneur-burn-rate-calculator',
};
if (redirects[slug!]) return Astro.redirect(`/${lang}/${redirects[slug!]}`);

const engine = getEngine(slug!);
if (!engine) return Astro.redirect(`/${lang}/`);

const related = relatedTools[slug!]?.map(s => tools.find(t => t.slug === s)!).filter(Boolean) ?? [];
const toolTitle = t(`tools.${slug}.title`, lang);
const toolDescription = t(`tools.${slug}.description`, lang);
const metaTitle = `${toolTitle} — CalcKit`;
const isInteractive = engine.inputs.length > 0;
const isClaude = slug === 'solopreneur-claude-api-cost-calculator';
const isDeepSeek = slug === 'solopreneur-deepseek-api-cost-calculator';
const isGemini = slug === 'solopreneur-gemini-api-cost-calculator';
const isAiApiCostComparison = slug === 'solopreneur-ai-api-cost-comparison';
// Business calculator → family config mapping (24 non-AI calcs, grouped by visual style)
const BIZ_CONFIG_MAP: Record<string, string> = {
  'solopreneur-mrr-calculator': 'BIZ_SAAS',
  'solopreneur-burn-rate-calculator': 'BIZ_SAAS',
  'solopreneur-churn-rate-calculator': 'BIZ_SAAS',
  'solopreneur-market-size-estimator': 'BIZ_SAAS',
  'solopreneur-revenue-projector': 'BIZ_SAAS',
  'solopreneur-ltv-calculator': 'BIZ_VALUATION',
  'solopreneur-cac-calculator': 'BIZ_VALUATION',
  'solopreneur-unit-economics-calculator': 'BIZ_VALUATION',
  'solopreneur-saas-valuation-calculator': 'BIZ_VALUATION',
  'solopreneur-equity-dilution-calculator': 'BIZ_VALUATION',
  'solopreneur-break-even-calculator': 'BIZ_VALUATION',
  'solopreneur-freelance-rate-calculator': 'BIZ_FREELANCE',
  'solopreneur-course-pricing-calculator': 'BIZ_FREELANCE',
  'solopreneur-time-value-calculator': 'BIZ_FREELANCE',
  'solopreneur-sponsorship-rate-calculator': 'BIZ_FREELANCE',
  'solopreneur-project-profitability-calculator': 'BIZ_FREELANCE',
  'solopreneur-affiliate-income-calculator': 'BIZ_FREELANCE',
  'solopreneur-email-list-revenue-calculator': 'BIZ_FREELANCE',
  'solopreneur-hourly-vs-fixed-calculator': 'BIZ_FREELANCE',
  'solopreneur-meeting-cost-calculator': 'BIZ_COST',
  'solopreneur-employee-cost-calculator': 'BIZ_COST',
  'solopreneur-productivity-score': 'BIZ_COST',
  'solopreneur-saas-pricing-planner': 'BIZ_COST',
  'solopreneur-freelance-tax-calculator': 'BIZ_COST',
};
const bizConfigKey = BIZ_CONFIG_MAP[slug!];
const isImage = slug === 'solopreneur-ai-image-cost-calculator';
const isTraining = slug === 'solopreneur-ai-training-cost-estimator';
const isGpu = slug === 'solopreneur-gpu-cloud-cost-calculator';
const clientConfig = JSON.stringify(engine.clientConfig);

const translatedFaq = engine.faq.map((item, i) => ({
  q: t(`tools.${slug}.faq.${i}.q`, lang),
  a: t(`tools.${slug}.faq.${i}.a`, lang),
}));
const translatedHowToUse = engine.howToUse.map((_, i) => t(`tools.${slug}.how_to_use.${i}`, lang));

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      mainEntity: translatedFaq.map(item => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
    {
      '@type': 'SoftwareApplication',
      name: toolTitle,
      applicationCategory: 'Multimedia',
      operatingSystem: 'Web',
      description: toolDescription,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: t('breadcrumb.home', lang), item: Astro.site?.toString() || '/' },
        { '@type': 'ListItem', position: 2, name: toolTitle },
      ],
    },
  ],
});
---

<BaseLayout title={metaTitle} description={toolDescription} schema={schema}>
  <Header />
  <main class="max-w-6xl mx-auto px-4 py-8 flex-1">
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href={`/${lang}/`} class="hover:text-[#7C3AED] transition-colors">{t('breadcrumb.home', lang)}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">{toolTitle}</span>
    </nav>

    <div class="lg:grid lg:grid-cols-5 lg:gap-10">
      <div class="lg:col-span-2">
        <div class="mb-6">
          <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 leading-tight">{toolTitle}</h1>
          <p class="text-sm text-gray-500 mt-2 leading-relaxed">{toolDescription}</p>
        </div>

        {isInteractive && (
          <form id="tool-form" class="mt-6 p-5 bg-white border border-gray-100 rounded-2xl shadow-sm">
            {/* OpenAI calculator: presets + token estimator + advanced collapse */}
            {slug === 'solopreneur-openai-token-calculator' ? (
              <>
                {/* Preset buttons */}
                <div class="mb-5">
                  <span class="block text-xs font-medium text-gray-400 mb-2 uppercase tracking-wide">{lang === 'zh' ? '🎭 场景预设' : '🎭 Scenario Presets'}</span>
                  <div class="flex flex-wrap gap-1.5" id="preset-buttons">
                    {[
                      { emoji:'🎧', en:'Support Bot', zh:'客服机器人', m:'gpt-5-mini', it:'800', ot:'200', rd:'500' },
                      { emoji:'📚', en:'RAG Q&A', zh:'RAG 问答', m:'gpt-4.1', it:'3000', ot:'400', rd:'200' },
                      { emoji:'💻', en:'Code Review', zh:'代码审查', m:'gpt-5.5', it:'5000', ot:'800', rd:'50' },
                      { emoji:'🌐', en:'Translation', zh:'文档翻译', m:'gpt-5', it:'2000', ot:'1500', rd:'100' },
                      { emoji:'✍️', en:'Content Gen', zh:'内容生成', m:'gpt-5.2', it:'500', ot:'2000', rd:'100' },
                      { emoji:'📊', en:'Data Analysis', zh:'数据分析', m:'o3', it:'4000', ot:'3000', rd:'30' },
                    ].map(p => (
                      <button type="button" class="preset-btn text-xs px-2.5 py-1.5 rounded-lg border border-gray-200 bg-gray-50 hover:border-[#7C3AED] hover:bg-[#7C3AED]/5 transition-all" data-models={p.m} data-it={p.it} data-ot={p.ot} data-rd={p.rd}>{p.emoji} {lang === 'zh' ? p.zh : p.en}</button>
                    ))}
                  </div>
                </div>

                {/* Token estimator */}
                <div class="mb-5">
                  <span class="block text-xs font-medium text-gray-400 mb-2 uppercase tracking-wide">{lang === 'zh' ? '📝 Token 估算器' : '📝 Token Estimator'}</span>
                  <textarea id="token-estimator" rows="3" placeholder={lang === 'zh' ? '粘贴你的提示文本...' : 'Paste your prompt text...'} class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all resize-none"></textarea>
                  <div id="token-estimate-result" class="text-xs text-gray-400 mt-1.5 hidden">
                    {lang === 'zh' ? '估算：输入 ~<span id="est-tokens">0</span> tokens' : 'Estimated: ~<span id="est-tokens">0</span> input tokens'}
                  </div>
                </div>

                {/* Core inputs: first 4 */}
                {engine.inputs.slice(0, 4).map(input => (
                  input.type === 'select' ? (
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                      <select id={input.name} name={input.name} class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 bg-white transition-all">
                        <option value="">{t('form.select', lang)}</option>
                        {input.options?.map(opt => <option value={opt}>{opt}</option>)}
                      </select>
                    </div>
                  ) : (
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                      <input type={input.type} id={input.name} name={input.name} placeholder={t(`tools.${slug}.input.${input.name}.placeholder`, lang)} value={input.name === 'models' ? 'gpt-5-mini,gpt-5.5,gpt-4.1' : ''} class="w-full pl-4 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all" />
                    </div>
                  )
                ))}

                {/* Advanced options: collapsed */}
                <details class="mb-4 group" id="advanced-options">
                  <summary class="text-xs font-medium text-gray-400 cursor-pointer hover:text-[#7C3AED] transition-colors select-none py-1">
                    {lang === 'zh' ? '⚙️ 高级选项' : '⚙️ Advanced Options'}
                  </summary>
                  <div class="mt-3 pt-3 border-t border-gray-100 space-y-0">
                    {engine.inputs.slice(4).map(input => (
                      input.type === 'select' ? (
                        <div class="mb-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                          <select id={input.name} name={input.name} class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 bg-white transition-all">
                            <option value="">{t('form.select', lang)}</option>
                            {input.options?.map(opt => <option value={opt} selected={opt === 'realtime'}>{opt}</option>)}
                          </select>
                        </div>
                      ) : (
                        <div class="mb-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                          <input type={input.type} id={input.name} name={input.name} placeholder={t(`tools.${slug}.input.${input.name}.placeholder`, lang)} class="w-full pl-4 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all" />
                        </div>
                      )
                    ))}
                  </div>
                </details>

                {/* Model hint */}
                <div class="mb-4 -mt-2">
                  <span class="text-xs text-gray-400">{lang === 'zh' ? '可用模型：' : 'Available: '}gpt-5.5, gpt-5.2, gpt-5, gpt-5-mini, gpt-5-nano, gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, o3, o4-mini, gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo</span>
                </div>
              </>
            ) : isClaude ? (
              <>
                {/* Preset buttons with emoji */}
                <div class="mb-5">
                  <span class="block text-xs font-medium text-gray-400 mb-2 uppercase tracking-wide">{lang === 'zh' ? '🎭 场景预设' : '🎭 Scenario Presets'}</span>
                  <div class="flex flex-wrap gap-1.5" id="preset-buttons-claude">
                    {[
                      { emoji:'🚀', en:'Small Project', zh:'小型项目', models:'claude-fable-5,claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5', it:'500', ot:'1000', rd:'50', pm:'realtime', cw:'500', cttl:'5min', chr:'80', gr:'0', pj:'12' },
                      { emoji:'📦', en:'Mid-Scale', zh:'中型规模', models:'claude-fable-5,claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5', it:'2000', ot:'1000', rd:'500', pm:'realtime', cw:'2000', cttl:'5min', chr:'60', gr:'0', pj:'12' },
                      { emoji:'🏭', en:'High Volume', zh:'高流量', models:'claude-fable-5,claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5', it:'5000', ot:'2000', rd:'5000', pm:'realtime', cw:'5000', cttl:'1hour', chr:'40', gr:'0', pj:'12' },
                      { emoji:'⚡', en:'Batch Processing', zh:'批量处理', models:'claude-fable-5,claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5', it:'3000', ot:'5000', rd:'10000', pm:'batch', cw:'0', cttl:'5min', chr:'0', gr:'0', pj:'12' },
                      { emoji:'💾', en:'Heavy Caching', zh:'重度缓存', models:'claude-fable-5,claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5', it:'2000', ot:'800', rd:'2000', pm:'realtime', cw:'2000', cttl:'1hour', chr:'90', gr:'0', pj:'12' },
                      { emoji:'🏢', en:'Enterprise', zh:'企业级', models:'claude-fable-5,claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5', it:'10000', ot:'5000', rd:'50000', pm:'batch', cw:'10000', cttl:'1hour', chr:'70', gr:'0', pj:'12' },
                    ].map(p => (
                      <button type="button" class="preset-btn preset-btn-claude text-xs px-2.5 py-1.5 rounded-lg border border-gray-200 bg-gray-50 hover:border-[#7C3AED] hover:bg-[#7C3AED]/5 transition-all" data-models={p.models} data-it={p.it} data-ot={p.ot} data-rd={p.rd} data-pm={p.pm} data-cw={p.cw} data-cttl={p.cttl} data-chr={p.chr} data-gr={p.gr} data-pj={p.pj}>{p.emoji} {lang === 'zh' ? p.zh : p.en}</button>
                    ))}
                  </div>
                </div>

                {/* Token estimator for Claude (~1.4 words/token English, ~0.65 chars/token CJK) */}
                <div class="mb-5">
                  <span class="block text-xs font-medium text-gray-400 mb-2 uppercase tracking-wide">{lang === 'zh' ? '📝 Token 估算器' : '📝 Token Estimator'}</span>
                  <textarea id="token-estimator" rows="3" placeholder={lang === 'zh' ? '粘贴你的提示文本...' : 'Paste your prompt text...'} class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all resize-none"></textarea>
                  <div id="token-estimate-result" class="text-xs text-gray-400 mt-1.5 hidden">
                    {lang === 'zh' ? '估算：输入 ~<span id="est-tokens">0</span> tokens (~1.4词/token 英文, ~0.65字/token CJK)' : 'Estimated: ~<span id="est-tokens">0</span> input tokens (~1.4 w/t EN, ~0.65 c/t CJK)'}
                  </div>
                </div>

                {/* Core inputs: first 4 */}
                {engine.inputs.slice(0, 4).map(input => (
                  input.type === 'select' ? (
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                      <select id={input.name} name={input.name} class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 bg-white transition-all">
                        <option value="">{t('form.select', lang)}</option>
                        {input.options?.map(opt => <option value={opt}>{opt}</option>)}
                      </select>
                    </div>
                  ) : (
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                      <input type={input.type} id={input.name} name={input.name} placeholder={t(`tools.${slug}.input.${input.name}.placeholder`, lang)} value={input.name === 'models' ? 'claude-fable-5,claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5' : ''} class="w-full pl-4 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all" />
                    </div>
                  )
                ))}

                {/* Advanced options: collapsed */}
                <details class="mb-4 group" id="advanced-options">
                  <summary class="text-xs font-medium text-gray-400 cursor-pointer hover:text-[#7C3AED] transition-colors select-none py-1">
                    {lang === 'zh' ? '⚙️ 高级选项（缓存、定价、增长预测）' : '⚙️ Advanced Options (Caching, Pricing, Growth)'}
                  </summary>
                  <div class="mt-3 pt-3 border-t border-gray-100 space-y-0">
                    {engine.inputs.slice(4).map(input => (
                      input.type === 'select' ? (
                        <div class="mb-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                          <select id={input.name} name={input.name} class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 bg-white transition-all">
                            <option value="">{t('form.select', lang)}</option>
                            {input.options?.map(opt => <option value={opt} selected={opt === 'realtime'}>{opt}</option>)}
                          </select>
                        </div>
                      ) : (
                        <div class="mb-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
                          <input type={input.type} id={input.name} name={input.name} placeholder={t(`tools.${slug}.input.${input.name}.placeholder`, lang)} class="w-full pl-4 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all" />
                        </div>
                      )
                    ))}
                  </div>
                </details>

                {/* Model hint */}
                <div class="mb-4 -mt-2">
                  <span class="text-xs text-gray-400">{lang === 'zh' ? '可用模型：' : 'Available: '}claude-fable-5, claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5, claude-opus-4-1, claude-haiku-3-5, claude-haiku-3</span>
                </div>
              </>
            ) : isDeepSeek ? (
              <>
                {/* Preset buttons with emoji */}
                <div class="mb-5">
                  <span class="block text-xs font-medium text-gray-400 mb-2 uppercase tracking-wide">{lang === 'zh' ? '🎭 场景预设' : '🎭 Scenario Presets'}</span>
                  <div class="flex flex-wrap gap-1.5" id="preset-buttons-deepseek">
                    {[
                      { emoji:'🔹', en:'Light Usage', zh:'轻量使用', models:'deepseek-v4-flash,deepseek-v4-pro-promo,deepseek-r1', it:'500', ot:'1000', rd:'50', chr:'80', gr:'0', pj:'12' },
                      { emoji:'📦', en:'Mid-Scale', zh:'中型规模', models:'deepseek-v4-flash,deepseek-v4-pro-promo,deepseek-r1', it:'2000', ot:'1000', rd:'500', chr:'60', gr:'0', pj:'12' },
                      { emoji:'🏭', en:'High Volume', zh:'高流量', models:'deepseek-v4-flash,deepseek-v4-pro-promo,deepseek-r1', it:'5000', ot:'2000', rd:'10000', chr:'50', gr:'0', pj:'12' },
                      { emoji:'💾', en:'Heavy Cache', zh:'重度缓存', models:'deepseek-v4-flash,deepseek-v4-pro-promo,deepseek-r1', it:'2000', ot:'800', rd:'5000', chr:'95', gr:'0', pj:'12' },
                      { emoji:'📈', en:'Growing App', zh:'增长中', models:'deepseek-v4-flash,deepseek-v4-pro-promo,deepseek-r1', it:'1000', ot:'800', rd:'200', chr:'70', gr:'10', pj:'12' },
                      { emoji:'🏢', en:'Enterprise', zh:'企业级', models:'deepseek-v4-flash,deepseek-v4-pro-promo,deepseek-r1', it:'8000', ot:'5000', rd:'100000', chr:'60', gr:'0', pj:'6' },
                    ].map(p => (
                      <button type="button" class="preset-btn preset-btn-deepseek text-xs px-2.5 py-1.5 rounded-lg border border-gray-200 bg-gray-50 hover:border-[#7C3AED] hover:bg-[#7C3AED]/5 transition-all" data-models={p.models} data-it={p.it} data-ot={p.ot} data-rd={p.rd} data-chr={p.chr} data-gr={p.gr} data-pj={p.pj}>{p.emoji} {lang === 'zh' ? p.zh : p.en}</button>
                    ))}
                  </div>
                </div>

                {/* Token estimator for DeepSeek (~1.3 words/token English, ~0.65 chars/token CJK) */}
                <div class="mb-5">
                  <span class="block text-xs font-medium text-gray-400 mb-2 uppercase tracking-wide">{lang === 'zh' ? '📝 Token 估算器' : '📝 Token Estimator'}</span>
                  <textarea id="token-estimator" rows="3" placeholder={lang === 'zh' ? '粘贴你的提示文本...' : 'Paste your prompt text...'} class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-[#7C3AED] focus:ring-2 focus:ring-[#7C3AED]/20 transition-all resize-none"></textarea>
                  <div id="token-estimate-result" class="text-xs text-gray-400 mt-1.5 hidden">
                    {lang === 'zh' ? '估算：输入 ~<span id="est-tokens">0</span> tokens (~1.3词/token 英文, ~0.65字/token CJK)' : 'Estimated: ~<span id="est-tokens">0</span> input tokens (~1.3 w/t EN, ~0.65 c/t CJK)'}
                  </div>
                </div>

                {/* Core inputs: first 4 */}
                {engine.inputs.slice(0, 4).map(input => (
                  input.type === 'select' ? (
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700 mb-2" for={input.name}>{t(`tools.${slug}.input.${input.name}.label`, lang)}</label>
