---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const title = 'Terms & Conditions — Solopreneur Tools';
const description = 'Terms and conditions for using Solopreneur Tools.';
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-8 flex-1">
    <h1 class="text-2xl font-extrabold mb-4">Terms & Conditions</h1>
    <div class="prose prose-sm max-w-none text-gray-700 leading-relaxed space-y-4">
      <p>Last updated: 2026</p>
      <h2>Acceptance of Terms</h2>
      <p>By accessing and using Solopreneur Tools, you accept and agree to be bound by these terms and conditions.</p>
      <h2>Use of the Service</h2>
      <p>All tools on this website are provided free of charge for personal and commercial use. You may use the generated content for your business and creative projects without attribution.</p>
      <h2>Disclaimer</h2>
      <p>The tools are provided "as is" without warranty of any kind. Results are generated algorithmically and should be reviewed before use. We are not responsible for any consequences of using the generated content.</p>
      <h2>Intellectual Property</h2>
      <p>The website design, code, and tool algorithms are the property of Solopreneur Tools. Generated output content belongs to you.</p>
    </div>
  </main>
  <Footer />
</BaseLayout>
