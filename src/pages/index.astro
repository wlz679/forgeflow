---
// SSG can't read cookies — use client-side redirect with cookie check
---
<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content="0;url=/en/" />
  <script>
    const m = document.cookie.match(/\byt-lang=(zh|en)\b/);
    window.location.replace('/' + (m ? m[1] : 'en') + '/');
  </script>
</head>
<body></body>
</html>
