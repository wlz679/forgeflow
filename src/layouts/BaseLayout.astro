---
import '../styles/global.css';
import { getLang, t } from '../i18n';
import { SITE_URL } from '../lib/site-config';
import { tools } from '../data/tools';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: string;
  pageType?: 'home' | 'tool' | 'article' | 'static';
}
const { title, description, ogImage = '/og-default.png', schema, pageType = 'static' } = Astro.props;
const lang = getLang(Astro);

const ogType = { home: 'website', tool: 'product', article: 'article', static: 'website' }[pageType];

// Whitelist of all 32 tool slugs. Consumed by src/scripts/recent-init.client.ts
// (getCurrentSlug) to decide whether a pathname like /en/foo/ refers to a real
// tool detail page (auto-record visit) vs. a static page (recent, favorites,
// about, contact, blog, etc.). Data-driven: re-derived from src/data/tools on
// every build, so adding a new tool automatically extends the whitelist.
const toolsSlugsJson = JSON.stringify(tools.map(tool => tool.slug));

const recentI18n = {
  en: {
    'recent.title': t('recent.title', 'en'),
    'recent.subtitle': t('recent.subtitle', 'en'),
    'recent.empty.title': t('recent.empty.title', 'en'),
    'recent.empty.body': t('recent.empty.body', 'en'),
    'recent.empty.browse': t('recent.empty.browse', 'en'),
    'recent.header_label': t('recent.header_label', 'en'),
    'recent.dropdown.view_all': t('recent.dropdown.view_all', 'en'),
    'recent.dropdown.empty': t('recent.dropdown.empty', 'en'),
    'recent.time.just_now': t('recent.time.just_now', 'en'),
    'recent.time.hours_ago': t('recent.time.hours_ago', 'en'),
    'recent.time.days_ago': t('recent.time.days_ago', 'en'),
  },
  zh: {
    'recent.title': t('recent.title', 'zh'),
    'recent.subtitle': t('recent.subtitle', 'zh'),
    'recent.empty.title': t('recent.empty.title', 'zh'),
    'recent.empty.body': t('recent.empty.body', 'zh'),
    'recent.empty.browse': t('recent.empty.browse', 'zh'),
    'recent.header_label': t('recent.header_label', 'zh'),
    'recent.dropdown.view_all': t('recent.dropdown.view_all', 'zh'),
    'recent.dropdown.empty': t('recent.dropdown.empty', 'zh'),
    'recent.time.just_now': t('recent.time.just_now', 'zh'),
    'recent.time.hours_ago': t('recent.time.hours_ago', 'zh'),
    'recent.time.days_ago': t('recent.time.days_ago', 'zh'),
  },
};
const recentI18nJson = JSON.stringify(recentI18n);

const historyI18n = {
  en: {
    'history.title': t('history.title', 'en'),
    'history.subtitle': t('history.subtitle', 'en'),
    'history.empty.title': t('history.empty.title', 'en'),
    'history.empty.body': t('history.empty.body', 'en'),
    'history.empty.browse': t('history.empty.browse', 'en'),
    'history.header_label': t('history.header_label', 'en'),
    'history.dropdown.view_all': t('history.dropdown.view_all', 'en'),
    'history.dropdown.empty': t('history.dropdown.empty', 'en'),
    'history.btn.save': t('history.btn.save', 'en'),
    'history.btn.saved': t('history.btn.saved', 'en'),
    'history.btn.restore': t('history.btn.restore', 'en'),
    'history.btn.delete': t('history.btn.delete', 'en'),
    'history.clear_all': t('history.clear_all', 'en'),
    'history.clear_all.confirm': t('history.clear_all.confirm', 'en'),
  },
  zh: {
    'history.title': t('history.title', 'zh'),
    'history.subtitle': t('history.subtitle', 'zh'),
    'history.empty.title': t('history.empty.title', 'zh'),
    'history.empty.body': t('history.empty.body', 'zh'),
    'history.empty.browse': t('history.empty.browse', 'zh'),
    'history.header_label': t('history.header_label', 'zh'),
    'history.dropdown.view_all': t('history.dropdown.view_all', 'zh'),
    'history.dropdown.empty': t('history.dropdown.empty', 'zh'),
    'history.btn.save': t('history.btn.save', 'zh'),
    'history.btn.saved': t('history.btn.saved', 'zh'),
    'history.btn.restore': t('history.btn.restore', 'zh'),
    'history.btn.delete': t('history.btn.delete', 'zh'),
    'history.clear_all': t('history.clear_all', 'zh'),
    'history.clear_all.confirm': t('history.clear_all.confirm', 'zh'),
  },
};
const historyI18nJson = JSON.stringify(historyI18n);

const siteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      url: SITE_URL,
      name: 'ForgeFlowKit',
      description: 'Free business calculators for solopreneurs and SaaS founders',
      inLanguage: ['en', 'zh'],
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${SITE_URL}/en/?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    },
  ],
});

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#org`,
      name: 'ForgeFlowKit',
      url: SITE_URL,
      logo: `${SITE_URL}/favicon.svg`,
      sameAs: [],
    },
  ],
});
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`${SITE_URL}${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="en" href={`${SITE_URL}/en${Astro.url.pathname.replace(/^\/(en|zh)/, '')}`} />
  <link rel="alternate" hreflang="zh" href={`${SITE_URL}/zh${Astro.url.pathname.replace(/^\/(en|zh)/, '')}`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE_URL}/en${Astro.url.pathname.replace(/^\/(en|zh)/, '')}`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${SITE_URL}${ogImage}`} />
  <meta property="og:type" content={ogType} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${SITE_URL}${ogImage}`} />
  <meta name="robots" content="index, follow" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3420554170441272" crossorigin="anonymous"></script>
  <script defer data-domain="forgeflowkit.com" src="https://plausible.io/js/script.js"></script>
  <script>
    import '../scripts/favorites-init.client.ts';
  </script>
  <script>
    import '../scripts/recent-init.client.ts';
  </script>
  <script>
    import '../scripts/history-init.client.ts';
  </script>
  <script>
    import '../scripts/clerk-init.client.ts';
  </script>
  <script is:inline set:html={`window.__i18n_recent__ = ${recentI18nJson};`}></script>
  <script is:inline set:html={`window.__i18n_history__ = ${historyI18nJson};`}></script>
  <script is:inline set:html={`window.__tools_slugs__ = ${toolsSlugsJson};`}></script>
  <script type="application/ld+json" set:html={siteSchema} />
  {pageType === 'home' && <script type="application/ld+json" set:html={orgSchema} />}
  {schema && <script type="application/ld+json" set:html={schema} />}
</head>
<body class="min-h-screen flex flex-col bg-white text-gray-900">
  <slot />
</body>
</html>
